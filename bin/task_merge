#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');
const { resolveBoardDir } = require('../lib/workdir');
const { readScalarText } = require('../lib/session_new');

function err(msg) {
  process.stderr.write(`Error: ${msg}\n`);
  process.exit(1);
}

function usage() {
  process.stdout.write('Usage: task_merge <task-file>\n');
}

function git(cwd, args) {
  return spawnSync('git', ['-C', cwd, ...args], { encoding: 'utf8' });
}

function hasWorktreeChanges(workspace) {
  const status = git(workspace, ['status', '--porcelain']);
  if (status.status !== 0) err(`Failed to read git status: ${status.stderr.trim()}`);
  return status.stdout.trim().length > 0;
}

function commitWorkspaceChanges(workspace, taskAbs) {
  if (!hasWorktreeChanges(workspace)) return false;

  const addResult = git(workspace, ['add', '--all']);
  if (addResult.status !== 0) err(`Failed to stage workspace changes: ${addResult.stderr.trim()}`);
  if (!hasWorktreeChanges(workspace)) return false;

  const taskName = path.basename(taskAbs, path.extname(taskAbs));
  const commitResult = spawnSync(
    'git',
    ['-C', workspace, 'commit', '-m', `konby task merge: ${taskName}`],
    { stdio: 'inherit' },
  );
  if (commitResult.status !== 0) process.exit(commitResult.status);
  return true;
}

function defaultBranch(repo) {
  const headRef = git(repo, ['symbolic-ref', '--quiet', 'refs/remotes/origin/HEAD']);
  if (headRef.status === 0 && headRef.stdout.trim()) {
    return headRef.stdout.trim().replace('refs/remotes/origin/', '');
  }
  for (const candidate of ['main', 'master', 'trunk']) {
    if (git(repo, ['show-ref', '--verify', '--quiet', `refs/heads/${candidate}`]).status === 0) {
      return candidate;
    }
  }
  return null;
}

function main() {
  const argv = process.argv.slice(2);
  if (argv.length === 0) { usage(); process.exit(1); }
  if (argv[0] === '--help' || argv[0] === '-h') { usage(); process.exit(0); }

  const taskFile = argv[0];
  if (!fs.existsSync(taskFile)) err(`Task file not found: ${taskFile}`);

  const taskAbs = path.resolve(taskFile);
  const boardDir = resolveBoardDir({ startDir: process.env.PWD || process.cwd(), taskFile: taskAbs });

  let workspace = readScalarText(fs.readFileSync(taskAbs, 'utf8'), 'workspace');
  if (!workspace) {
    workspace = boardDir;
  } else if (!path.isAbsolute(workspace)) {
    workspace = path.join(boardDir, workspace);
  }
  if (!fs.existsSync(workspace) || !fs.statSync(workspace).isDirectory()) {
    err(`workspace does not exist: ${workspace}`);
  }

  if (git(workspace, ['rev-parse', '--is-inside-work-tree']).status !== 0) {
    err('workspace is not a git repository');
  }

  const featureBranch = git(workspace, ['rev-parse', '--abbrev-ref', 'HEAD']).stdout.trim();
  if (featureBranch === 'HEAD') err('workspace is in detached HEAD state');

  const commonGitDirRaw = git(workspace, ['rev-parse', '--git-common-dir']).stdout.trim();
  const commonGitDir = path.isAbsolute(commonGitDirRaw)
    ? commonGitDirRaw
    : path.resolve(workspace, commonGitDirRaw);
  const repoRoot = path.dirname(commonGitDir);

  if (!fs.existsSync(path.join(repoRoot, '.git'))) {
    err('Could not resolve main repository from worktree');
  }

  const defaultBranchName = defaultBranch(repoRoot);
  if (!defaultBranchName) err('Could not determine default branch');
  if (featureBranch === defaultBranchName) {
    err(`Current branch equals default branch (${defaultBranchName}); nothing to merge`);
  }

  const currentMainBranch = git(repoRoot, ['rev-parse', '--abbrev-ref', 'HEAD']).stdout.trim();

  try {
    const committedWorkspaceChanges = commitWorkspaceChanges(workspace, taskAbs);

    const checkoutResult = git(repoRoot, ['checkout', defaultBranchName]);
    if (checkoutResult.status !== 0) {
      err(`Failed to checkout ${defaultBranchName}: ${checkoutResult.stderr.trim()}`);
    }

    const mergeResult = spawnSync('git', ['-C', repoRoot, 'merge', '--no-ff', featureBranch], { stdio: 'inherit' });
    if (mergeResult.status !== 0) process.exit(mergeResult.status);

    process.stdout.write(`Merged ${featureBranch} into ${defaultBranchName} in ${repoRoot}\n`);
    if (committedWorkspaceChanges) {
      process.stdout.write(`Committed pending workspace changes on ${featureBranch} before merge\n`);
    }
  } finally {
    git(repoRoot, ['checkout', currentMainBranch]);
  }
}

try {
  main();
} catch (e) {
  err(e.message);
}

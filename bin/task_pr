#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');
const { resolveBoardDir } = require('../lib/workdir');

function tryOpenBrowser(url) {
  const cmd = process.platform === 'darwin' ? 'open'
    : process.platform === 'win32' ? 'start'
    : 'xdg-open';
  try {
    spawnSync(cmd, [url], { encoding: 'utf8' });
  } catch (_) {}
}
const { taskBranchName } = require('../lib/worktree');
const { readScalarText } = require('../lib/session_new');
const { githubRepoSlug } = require('../lib/task_pr');

function err(msg) {
  process.stderr.write(`Error: ${msg}\n`);
  process.exit(1);
}

function usage() {
  process.stdout.write('Usage: task_pr <task-file>\n');
}

function git(cwd, args, opts = {}) {
  return spawnSync('git', ['-C', cwd, ...args], { encoding: 'utf8', ...opts });
}

function defaultBranch(repo) {
  const headRef = git(repo, ['symbolic-ref', '--quiet', 'refs/remotes/origin/HEAD']);
  if (headRef.status === 0 && headRef.stdout.trim()) {
    return headRef.stdout.trim().replace('refs/remotes/origin/', '');
  }
  for (const candidate of ['main', 'master', 'trunk']) {
    if (git(repo, ['show-ref', '--verify', '--quiet', `refs/heads/${candidate}`]).status === 0) {
      return candidate;
    }
  }
  return null;
}

function main() {
  const argv = process.argv.slice(2);
  if (argv.length === 0) { usage(); process.exit(1); }
  if (argv[0] === '--help' || argv[0] === '-h') { usage(); process.exit(0); }

  const taskFile = argv[0];
  if (!fs.existsSync(taskFile)) err(`Task file not found: ${taskFile}`);

  const taskAbs = path.resolve(taskFile);
  const boardDir = resolveBoardDir({ startDir: process.env.PWD || process.cwd(), taskFile: taskAbs });

  let workspace = readScalarText(fs.readFileSync(taskAbs, 'utf8'), 'workspace');
  if (!workspace) {
    workspace = boardDir;
  } else if (!path.isAbsolute(workspace)) {
    workspace = path.join(boardDir, workspace);
  }
  if (!fs.existsSync(workspace) || !fs.statSync(workspace).isDirectory()) {
    err(`workspace does not exist: ${workspace}`);
  }

  if (git(workspace, ['rev-parse', '--is-inside-work-tree']).status !== 0) {
    err('workspace is not a git repository');
  }

  const repoRoot = git(workspace, ['rev-parse', '--show-toplevel']).stdout.trim();

  const remoteUrlResult = git(repoRoot, ['remote', 'get-url', 'origin']);
  if (remoteUrlResult.status !== 0) err('Git remote origin is not configured');
  const remoteUrl = remoteUrlResult.stdout.trim();
  if (!remoteUrl.includes('github.com')) err(`origin remote is not GitHub: ${remoteUrl}`);

  const repoSlug = githubRepoSlug(remoteUrl);
  if (!repoSlug) err(`Could not parse GitHub repository from origin URL: ${remoteUrl}`);

  if (spawnSync('gh', ['--version'], { encoding: 'utf8' }).status !== 0) {
    err('gh CLI is not installed');
  }

  const defaultBranchName = defaultBranch(repoRoot);
  if (!defaultBranchName) err('Could not determine default branch');

  let currentBranch = git(workspace, ['rev-parse', '--abbrev-ref', 'HEAD']).stdout.trim();

  if (currentBranch === defaultBranchName) {
    const targetBranch = taskBranchName(taskAbs);
    const branchExists = git(repoRoot, ['show-ref', '--verify', '--quiet', `refs/heads/${targetBranch}`]).status === 0;
    const checkoutArgs = branchExists ? ['checkout', targetBranch] : ['checkout', '-b', targetBranch];
    const checkoutResult = git(workspace, checkoutArgs, { stdio: 'inherit' });
    if (checkoutResult.status !== 0) process.exit(checkoutResult.status);
    currentBranch = targetBranch;
  }

  const statusResult = git(workspace, ['status', '--porcelain']);
  if (statusResult.status === 0 && statusResult.stdout.trim()) {
    const addResult = git(workspace, ['add', '-A'], { stdio: 'inherit' });
    if (addResult.status !== 0) process.exit(addResult.status);
    const commitResult = git(workspace, ['commit', '-m', 'auto-commit: task changes'], { stdio: 'inherit' });
    if (commitResult.status !== 0) process.exit(commitResult.status);
  }

  const pushResult = spawnSync('git', ['-C', workspace, 'push', '-u', 'origin', currentBranch], { stdio: 'inherit' });
  if (pushResult.status !== 0) process.exit(pushResult.status);

  const existingPr = spawnSync('gh', ['pr', 'view', '--repo', repoSlug, currentBranch, '--json', 'url', '--jq', '.url'], { encoding: 'utf8' });
  if (existingPr.status === 0 && existingPr.stdout.trim()) {
    const url = existingPr.stdout.trim();
    process.stdout.write(`PR already exists: ${url}\n`);
    tryOpenBrowser(url);
    return;
  }

  const createResult = spawnSync('gh', ['pr', 'create', '--repo', repoSlug, '--base', defaultBranchName, '--head', currentBranch, '--fill'], { stdio: 'inherit' });
  if (createResult.status !== 0) process.exit(createResult.status);

  const newPrUrl = spawnSync('gh', ['pr', 'view', '--repo', repoSlug, currentBranch, '--json', 'url', '--jq', '.url'], { encoding: 'utf8' });
  const url = newPrUrl.stdout.trim();
  process.stdout.write(`Created PR: ${url}\n`);
  tryOpenBrowser(url);
}

try {
  main();
} catch (e) {
  err(e.message);
}

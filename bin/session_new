#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');
const { resolveBoardDir } = require('../lib/workdir');
const {
  agentSlugFromFile,
  buildPrompt,
  completionColumnValue,
  defaultTranscriptPath,
  parseSessionNewArgs,
  readBlockScalarText,
  readScalarText,
  readSchemaPropertyDefaultText,
  resolveWorkspaceDir,
  sessionIdForTask,
  sessionTimestampUtc,
  statusValues,
  transcriptAbsPath: transcriptAbsPathFn,
  transcriptPathRelativeToWorkspace,
  worktreePlan,
  yamlEscapeScalar,
} = require('../lib/session_new');
const { loadYaml, yamlScalar } = require('../lib/yaml');

function err(msg) {
  process.stderr.write(`Error: ${msg}\n`);
  process.exit(1);
}

function sleep(ms) {
  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms);
}

function tmuxHasSession(sessionId) {
  return spawnSync('tmux', ['has-session', '-t', sessionId], { encoding: 'utf8' }).status === 0;
}

function tmuxCapture(pane, lines = 200) {
  const out = spawnSync('tmux', ['capture-pane', '-t', pane, '-p', '-S', `-${lines}`], { encoding: 'utf8' });
  return out.status === 0 ? String(out.stdout || '') : '';
}

function tmuxSendLiteral(pane, text) {
  return spawnSync('tmux', ['send-keys', '-t', pane, '-l', '--', text], { encoding: 'utf8' }).status === 0;
}

function tmuxSendKey(pane, key) {
  return spawnSync('tmux', ['send-keys', '-t', pane, key], { encoding: 'utf8' }).status === 0;
}

function tmuxPaneCurrentCommand(pane) {
  const out = spawnSync('tmux', ['display-message', '-p', '-t', pane, '#{pane_current_command}'], { encoding: 'utf8' });
  return out.status === 0 ? String(out.stdout || '').trim() : '';
}

function firstCliCommandName(cli) {
  const token = String(cli || '').trim().split(/\s+/)[0] || '';
  return path.basename(token.replace(/^['"]|['"]$/g, ''));
}

function paneStillAtInteractiveShell(pane, cli) {
  const current = tmuxPaneCurrentCommand(pane);
  if (!current) return false;
  if (!/^(ba|z|fi|c|k|d)?sh$|^fish$|^tcsh$/.test(current)) return false;
  return current !== firstCliCommandName(cli);
}

function git(cwd, args, opts = {}) {
  return spawnSync('git', ['-C', cwd, ...args], { encoding: 'utf8', ...opts });
}

function hasGitChanges(repoRoot) {
  const status = git(repoRoot, ['status', '--porcelain']);
  if (status.status !== 0) err(`Failed to read git status: ${status.stderr.trim()}`);
  return status.stdout.trim().length > 0;
}

function ensureGitignoreEntry(repoRoot, entry) {
  const gitignorePath = path.join(repoRoot, '.gitignore');
  let content = '';
  try { content = fs.readFileSync(gitignorePath, 'utf8'); } catch (_) {}
  const lines = content.split(/\r?\n/);
  if (lines.some((l) => l.trim() === entry)) return;
  const newContent = content.endsWith('\n') || content === ''
    ? `${content}${entry}\n`
    : `${content}\n${entry}\n`;
  fs.writeFileSync(gitignorePath, newContent, 'utf8');
}

function commitPendingRepoChanges(repoRoot, taskAbsPath) {
  if (!hasGitChanges(repoRoot)) return false;

  const addResult = git(repoRoot, ['add', '--all']);
  if (addResult.status !== 0) err(`Failed to stage repository changes: ${addResult.stderr.trim()}`);
  if (!hasGitChanges(repoRoot)) return false;

  const taskName = path.basename(taskAbsPath, path.extname(taskAbsPath));
  const commitResult = git(
    repoRoot,
    ['commit', '-m', `konby worktree base: ${taskName}`],
    { stdio: 'inherit' },
  );
  if (commitResult.status !== 0) process.exit(commitResult.status);
  return true;
}

function currentHead(repoRoot) {
  const result = git(repoRoot, ['rev-parse', '--verify', 'HEAD']);
  if (result.status !== 0) err(`Failed to resolve HEAD: ${result.stderr.trim()}`);
  return result.stdout.trim();
}

function gitWorktrees(repoRoot) {
  const result = git(repoRoot, ['worktree', 'list', '--porcelain']);
  if (result.status !== 0) err(`Failed to list git worktrees: ${result.stderr.trim()}`);

  const out = [];
  let current = null;
  for (const line of result.stdout.split(/\r?\n/)) {
    if (line.startsWith('worktree ')) {
      if (current) out.push(current);
      current = { path: line.slice('worktree '.length), branch: '' };
    } else if (current && line.startsWith('branch ')) {
      current.branch = line.slice('branch '.length).replace(/^refs\/heads\//, '');
    }
  }
  if (current) out.push(current);
  return out;
}

function removeTaskWorktrees(repoRoot, branchName, plannedDir) {
  const plannedAbs = path.resolve(plannedDir);
  const paths = new Set();

  for (const wt of gitWorktrees(repoRoot)) {
    if (wt.branch === branchName && path.resolve(wt.path) !== path.resolve(repoRoot)) paths.add(wt.path);
  }
  if (fs.existsSync(plannedDir)) paths.add(plannedDir);

  for (const wtPath of paths) {
    const result = git(repoRoot, ['worktree', 'remove', '--force', wtPath], { stdio: 'inherit' });
    if (result.status !== 0 && path.resolve(wtPath) === plannedAbs && wtPath.includes(`${path.sep}.konby-worktrees${path.sep}`)) {
      fs.rmSync(wtPath, { recursive: true, force: true });
      git(repoRoot, ['worktree', 'prune']);
    } else if (result.status !== 0) {
      process.exit(result.status);
    }
  }
}

function deleteBranchIfExists(repoRoot, branchName) {
  const exists = git(repoRoot, ['show-ref', '--verify', '--quiet', `refs/heads/${branchName}`]).status === 0;
  if (!exists) return;

  const result = git(repoRoot, ['branch', '-D', branchName], { stdio: 'inherit' });
  if (result.status !== 0) process.exit(result.status);
}

function dispatchWorktreeSetupScript(boardDir) {
  const dispatchPath = path.join(boardDir, 'dispatch.yaml');
  if (!fs.existsSync(dispatchPath)) return '';
  const dispatch = loadYaml(dispatchPath);
  return String(((dispatch.worktree || {}).setup_script) || '').trim();
}

function runWorktreeSetupScript(script, worktreeDir) {
  if (!script) return;
  const result = spawnSync(script, {
    cwd: worktreeDir,
    shell: true,
    stdio: 'inherit',
  });
  if (result.error) err(`Failed to run worktree setup_script: ${result.error.message}`);
  if (result.status !== 0) {
    process.stderr.write(`Error: worktree setup_script failed with exit code ${result.status || 1}\n`);
    process.exit(result.status || 1);
  }
}

function resolveAgentFile(input, boardDir) {
  if (!input.includes('/') && !input.endsWith('.yml') && !input.endsWith('.yaml')) return null;
  const base = path.isAbsolute(input) ? input : path.join(boardDir, input);
  if (fs.existsSync(base)) return base;
  if (!base.endsWith('.yml') && !base.endsWith('.yaml')) {
    if (fs.existsSync(`${base}.yaml`)) return `${base}.yaml`;
    if (fs.existsSync(`${base}.yml`)) return `${base}.yml`;
  }
  return null;
}

function upsertTaskScalar(file, key, value) {
  const escaped = yamlScalar(String(value));
  const content = fs.readFileSync(file, 'utf8');
  const re = new RegExp(`^[ \\t]*${key}:[ \\t]*.*$`, 'm');
  let newContent;
  if (re.test(content)) {
    newContent = content.replace(re, `${key}: ${escaped}`);
  } else {
    newContent = `${content.trimEnd()}\n${key}: ${escaped}\n`;
  }
  fs.writeFileSync(file, newContent, 'utf8');
}

function captureVisible(pane) {
  const out = spawnSync('tmux', ['capture-pane', '-t', pane, '-p'], { encoding: 'utf8' });
  return out.status === 0 ? String(out.stdout || '') : '';
}

function handleStartupDialogs(pane, cli) {
  const out = captureVisible(pane);
  if (cli.includes('codex') && /Update available|Release notes: .*codex\/releases\/latest|Update now/i.test(out)) {
    tmuxSendLiteral(pane, '1');
    tmuxSendKey(pane, 'C-m');
    return true;
  }
  if (/Yes, I trust this folder|Do you trust the contents/i.test(out)) {
    tmuxSendKey(pane, 'C-m');
    return true;
  }
  return false;
}

function cleanupReadinessProbe(pane, probe) {
  for (let i = 0; i < probe.length; i += 1) {
    tmuxSendKey(pane, 'BSpace');
  }
  sleep(100);
}

function waitForCliReady(pane, cli, tries = Number(process.env.KONBY_SESSION_READY_TRIES || 120), delayMs = 500) {
  const probe = `konby-input-ready-${Date.now().toString(36)}-${Math.random().toString(36).slice(2)}`;
  if (tries > 0) sleep(delayMs);

  for (let i = 0; i < tries; i++) {
    if (handleStartupDialogs(pane, cli)) {
      sleep(delayMs);
      continue;
    }

    if (paneStillAtInteractiveShell(pane, cli)) {
      sleep(delayMs);
      continue;
    }

    if (!tmuxSendLiteral(pane, probe)) return false;
    sleep(delayMs);

    if (tmuxCapture(pane, 200).includes(probe)) {
      cleanupReadinessProbe(pane, probe);
      return true;
    }
  }
  return false;
}

function main() {
  const t0 = Date.now();
  const profile = !!process.env.KONBY_PROFILE;
  const mark = (label) => { if (profile) process.stderr.write(`[profile] +${Date.now() - t0}ms ${label}\n`); };

  let args;
  try {
    args = parseSessionNewArgs(process.argv.slice(2));
  } catch (e) {
    err(e.message);
  }

  if (args.help) {
    process.stdout.write(
      'Usage:\n' +
      '  session_new --agent <agent-file> --task <task-file> [--board <path>]\n' +
      '              [--transcript <path>] [--session-ts <UTC timestamp>]\n' +
      '              [--completion-column <column>]\n' +
      '              [--status-todo <status>] [--status-in-progress <status>]\n' +
      '              [--status-success <status>] [--status-failure <status>]\n\n' +
      'Example:\n' +
      '  session_new --agent agents/bsa.yaml --task tasks/task.yaml\n'
    );
    return;
  }

  mark('start');
  const resolveBoardOpts = { startDir: process.env.PWD || process.cwd(), taskFile: args.task };
  if (args.board) resolveBoardOpts.pathHint = args.board;
  const boardDir = resolveBoardDir(resolveBoardOpts);

  const taskAbsPath = path.isAbsolute(args.task) ? args.task : path.resolve(boardDir, args.task);
  if (!fs.existsSync(taskAbsPath)) err(`Task file not found: ${taskAbsPath}`);

  const agentFile = resolveAgentFile(args.agent, boardDir);
  if (!agentFile) err(`Agent file not found: ${args.agent}`);

  if (spawnSync('tmux', ['-V'], { encoding: 'utf8' }).status !== 0) err('tmux is not installed');
  mark('tmux -V');

  const agentContent = fs.readFileSync(agentFile, 'utf8');
  const taskContent = fs.readFileSync(taskAbsPath, 'utf8');

  const roleText = readBlockScalarText(agentContent, 'role');
  if (!roleText) err(`Could not read role block from ${agentFile}`);

  const cliCmd = readScalarText(agentContent, 'cli');
  if (!cliCmd) err(`Could not read cli from ${agentFile}`);

  const agentSlug = agentSlugFromFile(agentFile);
  const statusVals = statusValues(args);

  const taskColumn = readScalarText(taskContent, 'column') || readScalarText(taskContent, 'stage');
  const completionColumn = completionColumnValue(args.completionColumn, taskColumn);

  let workspaceDir = readScalarText(taskContent, 'workspace');
  const workspaceType = readScalarText(taskContent, 'workspace_type') || 'local';

  if (!workspaceDir) {
    const schemaPath = path.join(boardDir, 'task.schema.yaml');
    if (fs.existsSync(schemaPath)) {
      workspaceDir = readSchemaPropertyDefaultText(fs.readFileSync(schemaPath, 'utf8'), 'workspace');
    }
  }

  workspaceDir = resolveWorkspaceDir({ workspaceDir, schemaWorkspaceDefault: '', boardDir });
  mark('resolve workspace');

  if (workspaceType === 'worktree') {
    let repoRoot = null;
    let isWorktreeDir = false;

    const insideTree = spawnSync('git', ['-C', workspaceDir, 'rev-parse', '--is-inside-work-tree'], { encoding: 'utf8' });
    mark('git is-inside-work-tree');
    if (insideTree.status === 0 && fs.existsSync(workspaceDir)) {
      const gitPath = spawnSync('git', ['-C', workspaceDir, 'rev-parse', '--git-path', '.'], { encoding: 'utf8' });
      mark('git rev-parse --git-path');
      isWorktreeDir = String(gitPath.stdout || '').includes('/worktrees/');
      if (!isWorktreeDir) {
        repoRoot = spawnSync('git', ['-C', workspaceDir, 'rev-parse', '--show-toplevel'], { encoding: 'utf8' }).stdout.trim();
        mark('git show-toplevel');
      }
    } else {
      const boardInsideTree = spawnSync('git', ['-C', boardDir, 'rev-parse', '--is-inside-work-tree'], { encoding: 'utf8' });
      if (boardInsideTree.status !== 0) {
        err(`workspace_dir is not a git repository: ${workspaceDir}`);
      }
      repoRoot = spawnSync('git', ['-C', boardDir, 'rev-parse', '--show-toplevel'], { encoding: 'utf8' }).stdout.trim();
      mark('git is-inside-work-tree (boardDir)');
    }

    if (!isWorktreeDir && repoRoot) {
      const plan = worktreePlan(repoRoot, taskAbsPath);
      fs.mkdirSync(path.dirname(plan.dir), { recursive: true });
      if (!fs.existsSync(plan.dir)) {
        ensureGitignoreEntry(repoRoot, '.konby-worktrees');
        commitPendingRepoChanges(repoRoot, taskAbsPath);
        mark('commitPendingRepoChanges');
        const baseHead = currentHead(repoRoot);
        removeTaskWorktrees(repoRoot, plan.branch, plan.dir);
        deleteBranchIfExists(repoRoot, plan.branch);
        const addWorktree = spawnSync('git', ['-C', repoRoot, 'worktree', 'add', '-f', '-b', plan.branch, plan.dir, baseHead], { stdio: 'inherit' });
        if (addWorktree.status !== 0) process.exit(addWorktree.status);
        mark('git worktree add');
        const setupScript = dispatchWorktreeSetupScript(boardDir);
        if (setupScript) {
          runWorktreeSetupScript(setupScript, plan.dir);
          mark('worktree setup_script');
        }
      }
      workspaceDir = plan.dir;
      upsertTaskScalar(taskAbsPath, 'workspace', workspaceDir);
    }
  }

  if (!fs.existsSync(workspaceDir) || !fs.statSync(workspaceDir).isDirectory()) {
    err(`workspace_dir does not exist or is not a directory: ${workspaceDir}`);
  }

  const sessionTs = args.sessionTs || sessionTimestampUtc();
  const sessionId = sessionIdForTask(agentSlug, taskAbsPath, sessionTs);
  const paneTarget = `${sessionId}:0.0`;

  let transcriptRel = args.transcript;
  if (!transcriptRel) transcriptRel = defaultTranscriptPath(taskAbsPath, sessionId);
  const transcriptAbs = transcriptAbsPathFn(boardDir, transcriptRel);
  const transcriptRelToWorkspace = transcriptPathRelativeToWorkspace(transcriptAbs, workspaceDir);

  if (tmuxHasSession(sessionId)) err(`tmux session already exists: ${sessionId}`);
  mark('pre-tmux setup');

  const prompt = buildPrompt({
    roleText,
    taskText: taskContent,
    taskAbsPath,
    completionColumn,
    successStatus: statusVals.success,
    failureStatus: statusVals.failure,
    transcriptPath: transcriptRelToWorkspace,
    agentSlug,
  });

  spawnSync('tmux', ['new-session', '-d', '-s', sessionId, '-c', workspaceDir]);
  mark('tmux new-session');
  spawnSync('tmux', ['set-option', '-t', sessionId, 'mouse', 'on']);
  spawnSync('tmux', ['set-option', '-t', sessionId, 'set-clipboard', 'on']);
  spawnSync('tmux', ['bind-key', '-n', 'C-]', 'detach-client']);
  spawnSync('tmux', ['set-option', '-t', sessionId, 'status-right', 'Back to kanban board: Ctrl+]']);
  mark('tmux configure options');

  const hasPbcopy = spawnSync('which', ['pbcopy'], { encoding: 'utf8' }).status === 0;
  const hasPbpaste = spawnSync('which', ['pbpaste'], { encoding: 'utf8' }).status === 0;
  if (hasPbcopy && hasPbpaste) {
    spawnSync('tmux', ['bind-key', 'p', 'run-shell', 'pbpaste | tmux load-buffer - ; tmux paste-buffer']);
  }
  mark('tmux clipboard setup');

  sleep(200);
  mark('sleep(200)');

  tmuxSendLiteral(paneTarget, cliCmd);
  tmuxSendKey(paneTarget, 'C-m');
  mark('send CLI command');

  if (!waitForCliReady(paneTarget, cliCmd)) {
    err(`Timed out waiting for CLI input readiness in session ${sessionId}`);
  }
  mark('waitForCliReady');

  tmuxSendLiteral(paneTarget, '\x1b[200~');
  spawnSync('tmux', ['set-buffer', '--', prompt]);
  spawnSync('tmux', ['paste-buffer', '-t', paneTarget]);
  tmuxSendLiteral(paneTarget, '\x1b[201~');
  tmuxSendKey(paneTarget, 'C-m');
  mark('paste prompt');

  if (!tmuxHasSession(sessionId)) err(`tmux session failed to stay alive: ${sessionId}`);

  process.stdout.write(`Started tmux session: ${sessionId}\n`);
  mark('done');
}

try {
  main();
} catch (e) {
  err(e.message);
}

#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');

const KONBY_HOME = path.join(__dirname, '..');
const KONBY_BIN_DIR = __dirname;

function konbyVersion() {
  try {
    const pkg = JSON.parse(fs.readFileSync(path.join(KONBY_HOME, 'package.json'), 'utf8'));
    return pkg.version || 'unknown';
  } catch (_) {
    return 'unknown';
  }
}

function usage() {
  const version = konbyVersion();
  process.stdout.write(`konby - streamline teams of agents using kanban boards
version: ${version}

Usage steps:
  1. Create a new board:
    \`konby board new <path> [--preset <name>] [--workspace <path>] [--force]\`

  2. Adjust rules if needed:
    - board structure and dispatching rules in <path>/dispatch.yaml
    - agents roles in<path>/agents/*.yaml

  3. Add a task to the board (stored in <path>/tasks/*.yml):
    \`konby task add --description "..." [--board <path>]\`
    \`konby task move <task-file> [--column <column>] [--status <status>] [--assignee <assignee>] [--comment "<comment>"] [--attachment <path>]\`
    \`konby task comment <task-file> "<comment>"\`

  4. Run dispatcher continuously in background loop:
    \`konby dispatchd [--log-file <path>] [--board <path>]\`

  5. Watch tasks getting done:
    \`konby board show [--board <path>]\`

Additional commands:
  konby help
    This help message.
  konby task move <task-file> [--column <column>] [--status <status>] [--assignee <assignee>] [--comment "<comment>"] [--attachment <path>]
    Move/update task fields and optionally append a comment.
  konby task comment <task-file> "<comment>"
    Append a comment to the task.
  konby task pr <task-file>
    Create/switch branch and open GitHub PR for the task workspace.
  konby task merge <task-file>
    Merge current worktree branch into repository default branch locally.
  konby session new --agent <agent-file> --task <task-file> [--board <path>]
    Manually start a tmux agent session for one task.
  konby dispatch [--board <path>]
    Nudge dispatcher once to apply dispatch.yaml rules, move tasks, and trigger agent sessions.

Examples:
  konby task add --description "Add OAuth login" --board ./my-board
  konby task move ./my-board/tasks/10-login.yml --column in_progress --status in_progress --assignee coder --comment "Picked up for implementation"
  konby task comment ./my-board/tasks/10-login.yml "Need clarification on acceptance criteria"
  konby dispatchd --log-file /tmp/konby-dispatchd.log --board ./my-board
`);
}

function err(msg) {
  process.stderr.write(`Error: ${msg}\n`);
  process.exit(1);
}

function run(scriptName, args) {
  const scriptPath = path.join(KONBY_BIN_DIR, scriptName);
  const result = spawnSync(scriptPath, args, { stdio: 'inherit' });
  process.exit(result.status ?? 1);
}

function ensurePath(shellName) {
  let rcFile;
  if (shellName === 'zsh') rcFile = path.join(process.env.HOME, '.zshrc');
  else if (shellName === 'bash') rcFile = path.join(process.env.HOME, '.bashrc');
  else err(`Unsupported shell: ${shellName} (expected zsh or bash)`);

  const line = `export PATH="${KONBY_BIN_DIR}:$PATH"`;
  if (!fs.existsSync(rcFile)) fs.writeFileSync(rcFile, '');
  const content = fs.readFileSync(rcFile, 'utf8');
  if (content.includes(line)) {
    process.stdout.write(`PATH already configured in ${rcFile}\n`);
  } else {
    fs.appendFileSync(rcFile, `\n${line}\n`);
    process.stdout.write(`Added to ${rcFile}: ${line}\n`);
  }

  process.env.PATH = `${KONBY_BIN_DIR}:${process.env.PATH}`;
  process.stdout.write('PATH updated for current shell process.\n');
}

function cmdInstall(argv) {
  let shellName = 'zsh';
  let boardName = '';
  let targetDir = process.cwd();
  let presetName = 'swe';

  for (let i = 0; i < argv.length; i++) {
    switch (argv[i]) {
      case '--shell':
        if (!argv[i + 1]) err('Missing value after --shell');
        shellName = argv[++i];
        break;
      case '--board':
        if (!argv[i + 1]) err('Missing value after --board');
        boardName = argv[++i];
        break;
      case '--dir':
        if (!argv[i + 1]) err('Missing value after --dir');
        targetDir = argv[++i];
        break;
      case '--preset':
        if (!argv[i + 1]) err('Missing value after --preset');
        presetName = argv[++i];
        break;
      default:
        err(`Unknown option for install: ${argv[i]}`);
    }
  }

  ensurePath(shellName);

  if (boardName) {
    const boardPath = path.join(targetDir, boardName);
    const boardNewScript = path.join(KONBY_BIN_DIR, 'board_new');
    const result = spawnSync(boardNewScript, [boardPath, '--preset', presetName], { stdio: 'inherit' });
    if (result.status !== 0) process.exit(result.status ?? 1);
  }

  process.stdout.write(`If command is not found in your current terminal, run: source ~/.${shellName}rc\n`);
}

function main() {
  const argv = process.argv.slice(2);
  if (argv.length === 0) { usage(); process.exit(0); }

  switch (argv[0]) {
    case 'help':
    case '--help':
    case '-h':
      usage();
      break;
    case 'install':
      cmdInstall(argv.slice(1));
      break;
    case 'board': {
      const sub = argv[1];
      if (!sub) err('Usage: konby board <new|show> ...');
      if (sub === 'new') run('board_new', argv.slice(2));
      else if (sub === 'show') run('board_show', argv.slice(2));
      else err(`Unknown board subcommand: ${sub}`);
      break;
    }
    case 'task': {
      const sub = argv[1];
      if (!sub) err('Usage: konby task <add|move|comment|pr|merge> ...');
      if (sub === 'add') run('task_add', argv.slice(2));
      else if (sub === 'move') run('task_move', argv.slice(2));
      else if (sub === 'comment') run('task_comment', argv.slice(2));
      else if (sub === 'pr') run('task_pr', argv.slice(2));
      else if (sub === 'merge') run('task_merge', argv.slice(2));
      else err(`Unknown task subcommand: ${sub}`);
      break;
    }
    case 'session': {
      const sub = argv[1];
      if (!sub) err('Usage: konby session new ...');
      if (sub === 'new') run('session_new', argv.slice(2));
      else err(`Unknown session subcommand: ${sub}`);
      break;
    }
    case 'dispatch':
      run('dispatch', argv.slice(1));
      break;
    case 'dispatchd':
      run('dispatchd', argv.slice(1));
      break;
    default:
      err(`Unknown command: ${argv[0]}`);
  }
}

try {
  main();
} catch (e) {
  err(e.message);
}

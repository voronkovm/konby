#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');

function parseScalar(value) {
  if (value === 'true') return true;
  if (value === 'false') return false;
  if (value === 'null') return null;
  if (/^-?\d+(\.\d+)?$/.test(value)) return Number(value);
  if (value === '-') return '-';
  if ((value.startsWith('"') && value.endsWith('"')) || (value.startsWith("'") && value.endsWith("'"))) {
    return value.slice(1, -1);
  }
  return value;
}

function parseYamlSimple(input) {
  const root = {};
  const stack = [{ indent: -1, kind: 'object', value: root }];
  const lines = input.replace(/\t/g, '  ').split(/\r?\n/);

  for (let idx = 0; idx < lines.length; idx += 1) {
    const raw = lines[idx];
    if (!raw.trim() || raw.trim().startsWith('#')) continue;

    const indent = raw.match(/^\s*/)[0].length;
    const line = raw.trim();

    while (stack.length > 1 && indent <= stack[stack.length - 1].indent) stack.pop();
    const parent = stack[stack.length - 1];

    if (line.startsWith('- ')) {
      if (parent.kind !== 'array') throw new Error(`Invalid YAML list item at line ${idx + 1}`);
      const content = line.slice(2).trim();
      if (!content) {
        const node = {};
        parent.value.push(node);
        stack.push({ indent, kind: 'object', value: node });
        continue;
      }
      const keyMatch = content.match(/^([^:]+):(.*)$/);
      if (keyMatch) {
        const key = keyMatch[1].trim();
        const rawValue = keyMatch[2].trim();
        const node = {};
        node[key] = rawValue ? parseScalar(rawValue) : {};
        parent.value.push(node);
        if (!rawValue) stack.push({ indent, kind: 'object', value: node[key] });
        else stack.push({ indent, kind: 'object', value: node });
        continue;
      }
      parent.value.push(parseScalar(content));
      continue;
    }

    if (parent.kind !== 'object') throw new Error(`Invalid YAML map entry at line ${idx + 1}`);

    const match = line.match(/^([^:]+):(.*)$/);
    if (!match) throw new Error(`Cannot parse YAML line ${idx + 1}: ${line}`);

    const key = match[1].trim();
    const rawValue = match[2].trim();

    if (!rawValue) {
      const nextLine = lines.slice(idx + 1).find((l) => l.trim() && !l.trim().startsWith('#'));
      const nextTrim = nextLine ? nextLine.trim() : '';
      const isArray = nextTrim.startsWith('- ');
      if (isArray) {
        const arr = [];
        parent.value[key] = arr;
        stack.push({ indent, kind: 'array', value: arr });
      } else {
        const obj = {};
        parent.value[key] = obj;
        stack.push({ indent, kind: 'object', value: obj });
      }
      continue;
    }

    parent.value[key] = parseScalar(rawValue);
  }

  return root;
}

function loadYaml(filePath) {
  return parseYamlSimple(fs.readFileSync(filePath, 'utf8'));
}

function yamlScalar(value) {
  if (value === null) return 'null';
  if (typeof value === 'number' || typeof value === 'boolean') return String(value);
  if (typeof value === 'string' && /^[A-Za-z0-9_./:@+-]+$/.test(value)) return value;
  return JSON.stringify(value);
}

function formatYaml(value, indent = 0) {
  const sp = ' '.repeat(indent);
  if (Array.isArray(value)) {
    if (value.length === 0) return `${sp}[]`;
    return value.map((item) => {
      if (item && typeof item === 'object' && !Array.isArray(item)) {
        const nested = formatYaml(item, indent + 2).split('\n');
        return `${sp}- ${nested[0].trimStart()}\n${nested.slice(1).join('\n')}`;
      }
      return `${sp}- ${yamlScalar(item)}`;
    }).join('\n');
  }

  const lines = [];
  for (const [key, val] of Object.entries(value)) {
    if (Array.isArray(val)) {
      if (val.length === 0) lines.push(`${sp}${key}: []`);
      else lines.push(`${sp}${key}:\n${formatYaml(val, indent + 2)}`);
      continue;
    }
    if (val && typeof val === 'object') {
      lines.push(`${sp}${key}:\n${formatYaml(val, indent + 2)}`);
      continue;
    }
    lines.push(`${sp}${key}: ${yamlScalar(val)}`);
  }
  return lines.join('\n');
}

function saveYaml(filePath, obj) {
  fs.writeFileSync(filePath, `${formatYaml(obj)}\n`, 'utf8');
}

function ensureDir(p) {
  fs.mkdirSync(p, { recursive: true });
}

function sanitizePathToken(value, fallback) {
  const safe = String(value || '')
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9._-]+/g, '_')
    .replace(/^_+|_+$/g, '');
  return safe || fallback;
}

function listSessionsForTask(taskFile) {
  const taskBase = path.basename(taskFile);
  const taskSlug = taskBase.replace(/\.ya?ml$/i, '');
  const out = spawnSync('tmux', ['list-sessions', '-F', '#{session_name}\t#{session_created}'], { encoding: 'utf8' });
  if (out.status !== 0) return [];
  const taskToken = `___${taskSlug}__`;
  return String(out.stdout || '')
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter(Boolean)
    .map((line) => {
      const [name, createdRaw] = line.split('\t');
      const created = Number(createdRaw || 0);
      return { name: String(name || ''), created: Number.isFinite(created) ? created : 0 };
    })
    .filter((entry) => entry.name.includes(taskToken))
    .sort((a, b) => b.created - a.created);
}

function captureTmux(sessionId) {
  const out = spawnSync('tmux', ['capture-pane', '-J', '-t', sessionId, '-p', '-S', '-', '-E', '-'], {
    encoding: 'utf8',
  });
  if (out.status !== 0) return { ok: false, full: '', error: `${out.stderr || out.stdout || 'tmux capture failed'}`.trim() };
  const full = String(out.stdout || '').split(/\r?\n/).join('\n').trimEnd();
  if (!full) return { ok: false, full: '', error: 'empty terminal output' };
  return { ok: true, full, error: '' };
}

function transcriptFileForSession(projectDir, taskFile, sessionId) {
  const taskSlug = sanitizePathToken(path.basename(taskFile).replace(/\.ya?ml$/i, ''), 'task');
  const rawSessionSlug = sanitizePathToken(sessionId || 'session', 'session');
  const taskToken = `___${taskSlug}__`;
  const sessionSlug = rawSessionSlug.includes(taskToken)
    ? rawSessionSlug.replace(taskToken, '__')
    : rawSessionSlug;
  const transcriptsDir = path.join(projectDir, 'transcripts', taskSlug);
  ensureDir(transcriptsDir);
  return path.join(transcriptsDir, `${sessionSlug}.txt`);
}

function guessProjectDir(taskFileAbs) {
  const taskDir = path.dirname(taskFileAbs);
  if (path.basename(taskDir) === 'tasks') return path.dirname(taskDir);
  return process.cwd();
}

function closeTaskSessionsOnAssigneeChange(projectDir, taskFile) {
  const sessions = listSessionsForTask(taskFile);
  let closed = 0;
  let transcriptUpdated = 0;
  for (const session of sessions) {
    const cap = captureTmux(session.name);
    if (cap.ok) {
      const transcriptAbsPath = transcriptFileForSession(projectDir, taskFile, session.name);
      const nextTranscript = cap.full.endsWith('\n') ? cap.full : `${cap.full}\n`;
      const prevTranscript = fs.existsSync(transcriptAbsPath) ? fs.readFileSync(transcriptAbsPath, 'utf8') : null;
      if (prevTranscript === null || prevTranscript !== nextTranscript) {
        fs.writeFileSync(transcriptAbsPath, nextTranscript, 'utf8');
        transcriptUpdated += 1;
      }
    }
    const kill = spawnSync('tmux', ['kill-session', '-t', session.name], { encoding: 'utf8' });
    if (kill.status === 0) closed += 1;
  }
  return { found: sessions.length, closed, transcriptUpdated };
}

function usage() {
  process.stdout.write('Usage: task_move <task-file> [--column <column>] [--status <status>] [--assignee <assignee>] [--comment "<comment>"] [--transcript <path>]\n');
}

function main() {
  const argv = process.argv.slice(2);
  if (argv.length === 0 || argv.includes('--help') || argv.includes('-h')) {
    usage();
    return;
  }

  const taskFile = argv[0];
  let column;
  let status;
  let assignee;
  let comment;
  let transcript;

  for (let i = 1; i < argv.length; i += 1) {
    const token = argv[i];
    if (token === '--column') {
      if (!argv[i + 1]) throw new Error('Missing value after --column');
      column = argv[i + 1];
      i += 1;
      continue;
    }
    if (token === '--stage') {
      if (!argv[i + 1]) throw new Error('Missing value after --stage');
      column = argv[i + 1];
      i += 1;
      continue;
    }
    if (token === '--status') {
      if (!argv[i + 1]) throw new Error('Missing value after --status');
      status = argv[i + 1];
      i += 1;
      continue;
    }
    if (token === '--assignee') {
      if (!argv[i + 1]) throw new Error('Missing value after --assignee');
      assignee = argv[i + 1];
      i += 1;
      continue;
    }
    if (token === '--comment') {
      if (!argv[i + 1]) throw new Error('Missing value after --comment');
      comment = argv[i + 1];
      i += 1;
      continue;
    }
    if (token === '--transcript') {
      if (!argv[i + 1]) throw new Error('Missing value after --transcript');
      transcript = argv[i + 1];
      i += 1;
      continue;
    }
    throw new Error(`Unknown argument: ${token}`);
  }

  if (column === undefined && status === undefined && assignee === undefined && comment === undefined && transcript === undefined) {
    throw new Error('At least one of --column, --status, --assignee, --comment, --transcript must be provided');
  }

  const fullTaskPath = path.resolve(taskFile);
  if (!fs.existsSync(fullTaskPath)) throw new Error(`Task file not found: ${fullTaskPath}`);
  const projectDir = guessProjectDir(fullTaskPath);

  const data = loadYaml(fullTaskPath);
  const prevAssignee = String(data.assignee || '').trim();
  if (column !== undefined) data.column = column;
  if (status !== undefined) data.status = status;
  if (assignee !== undefined) data.assignee = assignee;
  if (comment !== undefined || transcript !== undefined) {
    const commentText = comment === undefined ? '' : String(comment).trim();
    const transcriptText = transcript === undefined ? '' : String(transcript).trim();
    if (comment !== undefined && !commentText) throw new Error('--comment cannot be empty');
    if (transcript !== undefined && !transcriptText) throw new Error('--transcript cannot be empty');
    const statusForComment = String(data.status || status || '').trim() || 'unknown';
    const text = commentText
      ? `status: ${statusForComment}, ${commentText}`
      : `status: ${statusForComment}`;
    if (!Array.isArray(data.comments)) data.comments = [];
    const nextComment = {
      author: 'user',
      text,
      created_at: new Date().toISOString(),
    };
    if (transcriptText) nextComment.transcript = transcriptText;
    data.comments.push(nextComment);
  }
  let sessionResult = null;
  if (assignee !== undefined) {
    const nextAssignee = String(data.assignee || '').trim();
    if (nextAssignee !== prevAssignee) {
      sessionResult = closeTaskSessionsOnAssigneeChange(projectDir, fullTaskPath);
    }
  }
  data.updated_at = new Date().toISOString();
  saveYaml(fullTaskPath, data);

  process.stdout.write(`Task updated: ${fullTaskPath}\n`);
  if (sessionResult) {
    process.stdout.write(
      `Task sessions: found=${sessionResult.found}, closed=${sessionResult.closed}, transcript_updated=${sessionResult.transcriptUpdated}\n`,
    );
  }
}

try {
  main();
} catch (err) {
  process.stderr.write(`Error: ${err.message}\n`);
  process.exit(1);
}

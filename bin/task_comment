#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { loadYaml } = require('../lib/yaml');
const { saveTaskYamlOrdered } = require('../lib/task_yaml');

function usage() {
  process.stdout.write('Usage: task_comment <task-file> "<comment>"\n');
}

function main() {
  const argv = process.argv.slice(2);
  if (argv.length === 0 || argv.includes('--help') || argv.includes('-h')) {
    usage();
    return;
  }

  const taskFile = argv[0];
  const comment = argv[1];
  if (!taskFile || !comment) {
    throw new Error('Usage: task_comment <task-file> "<comment>"');
  }

  const fullTaskPath = path.resolve(taskFile);
  if (!fs.existsSync(fullTaskPath)) throw new Error(`Task file not found: ${fullTaskPath}`);

  const data = loadYaml(fullTaskPath);
  if (!Array.isArray(data.updates)) data.updates = [];
  data.updates.push({
    author: 'user',
    text: comment,
    created_at: new Date().toISOString(),
  });
  data.updated_at = new Date().toISOString();
  saveTaskYamlOrdered(fullTaskPath, data);

  process.stdout.write(`Comment added: ${fullTaskPath}\n`);
}

try {
  main();
} catch (err) {
  process.stderr.write(`Error: ${err.message}\n`);
  process.exit(1);
}

#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { copyPresetTree, createFileIfMissing, setWorkspaceDefaultContent } = require('../lib/board_new');

const KONBY_HOME = path.join(__dirname, '..');

function usage() {
  process.stdout.write('Usage:\n  board_new <path> [--preset <name>] [--workspace <path>] [--force]\n');
}

function err(msg) {
  process.stderr.write(`Error: ${msg}\n`);
  process.exit(1);
}

function resolvePresetDir(presetName) {
  const presetDir = path.join(KONBY_HOME, 'presets', presetName);
  if (!fs.existsSync(presetDir) || !fs.statSync(presetDir).isDirectory()) {
    err(`Preset not found: ${presetName} (${presetDir})`);
  }
  if (!fs.existsSync(path.join(presetDir, 'dispatch.yaml'))) {
    err(`Preset ${presetName} missing dispatch.yaml`);
  }
  if (!fs.existsSync(path.join(presetDir, 'task.schema.yaml'))) {
    err(`Preset ${presetName} missing task.schema.yaml`);
  }
  const agentsDir = path.join(presetDir, 'agents');
  if (!fs.existsSync(agentsDir) || !fs.statSync(agentsDir).isDirectory()) {
    err(`Preset ${presetName} missing agents/ directory`);
  }
  return presetDir;
}

function setWorkspaceDefault(schemaFile, workspacePath) {
  const raw = fs.readFileSync(schemaFile, 'utf8');
  fs.writeFileSync(schemaFile, setWorkspaceDefaultContent(raw, workspacePath), 'utf8');
  process.stdout.write(`Updated workspace default in: ${schemaFile}\n`);
}

function main() {
  const argv = process.argv.slice(2);
  if (argv.length === 0) { usage(); process.exit(1); }
  if (argv[0] === '--help' || argv[0] === '-h') { usage(); process.exit(0); }

  const boardPath = argv[0];
  let presetName = 'swe';
  let workspacePath = '';
  let force = false;

  for (let i = 1; i < argv.length; i++) {
    switch (argv[i]) {
      case '--preset':
        if (!argv[i + 1]) err('Missing value after --preset');
        presetName = argv[++i];
        break;
      case '--workspace':
        if (!argv[i + 1]) err('Missing value after --workspace');
        workspacePath = argv[++i];
        break;
      case '--force':
        force = true;
        break;
      default:
        err(`Unknown argument: ${argv[i]}`);
    }
  }

  if (!boardPath) err('Board path is required');
  const presetDir = resolvePresetDir(presetName);
  const targetDir = path.isAbsolute(boardPath) ? boardPath : path.join(process.cwd(), boardPath);

  fs.mkdirSync(targetDir, { recursive: true });
  copyPresetTree(presetDir, targetDir, force);
  fs.mkdirSync(path.join(targetDir, 'tasks'), { recursive: true });
  fs.mkdirSync(path.join(targetDir, 'transcripts'), { recursive: true });
  process.stdout.write('Ensured dirs: tasks/ transcripts/\n');

  if (workspacePath) {
    if (!path.isAbsolute(workspacePath)) workspacePath = path.join(process.cwd(), workspacePath);
    if (fs.existsSync(workspacePath) && fs.statSync(workspacePath).isDirectory()) {
      workspacePath = fs.realpathSync(workspacePath);
    }
    setWorkspaceDefault(path.join(targetDir, 'task.schema.yaml'), workspacePath);
  }

  process.stdout.write(`Board initialized in: ${targetDir} (preset: ${presetName})\n`);
}

try {
  main();
} catch (e) {
  err(e.message);
}

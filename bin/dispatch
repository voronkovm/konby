#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const os = require('os');
const { spawnSync } = require('child_process');

function parseScalar(value) {
  if (value === 'true') return true;
  if (value === 'false') return false;
  if (value === 'null') return null;
  if (/^-?\d+(\.\d+)?$/.test(value)) return Number(value);
  if (value === '-') return '-';
  if (value === '"*"') return '*';
  if ((value.startsWith('"') && value.endsWith('"')) || (value.startsWith("'") && value.endsWith("'"))) {
    return value.slice(1, -1);
  }
  return value;
}

function parseYamlSimple(input) {
  const root = {};
  const stack = [{ indent: -1, kind: 'object', value: root }];
  const lines = input.replace(/\t/g, '  ').split(/\r?\n/);

  for (let idx = 0; idx < lines.length; idx += 1) {
    const raw = lines[idx];
    if (!raw.trim() || raw.trim().startsWith('#')) continue;

    const indent = raw.match(/^\s*/)[0].length;
    const line = raw.trim();

    while (stack.length > 1 && indent <= stack[stack.length - 1].indent) stack.pop();
    const parent = stack[stack.length - 1];

    if (line.startsWith('- ')) {
      if (parent.kind !== 'array') throw new Error(`Invalid YAML list item at line ${idx + 1}`);
      const content = line.slice(2).trim();
      if (!content) {
        const node = {};
        parent.value.push(node);
        stack.push({ indent, kind: 'object', value: node });
        continue;
      }
      const keyMatch = content.match(/^([^:]+):(.*)$/);
      if (keyMatch) {
        const key = keyMatch[1].trim();
        const rawValue = keyMatch[2].trim();
        const node = {};
        node[key] = rawValue ? parseScalar(rawValue) : {};
        parent.value.push(node);
        if (!rawValue) {
          stack.push({ indent, kind: 'object', value: node[key] });
        } else {
          stack.push({ indent, kind: 'object', value: node });
        }
        continue;
      }
      parent.value.push(parseScalar(content));
      continue;
    }

    if (parent.kind !== 'object') throw new Error(`Invalid YAML map entry at line ${idx + 1}`);

    const match = line.match(/^([^:]+):(.*)$/);
    if (!match) throw new Error(`Cannot parse YAML line ${idx + 1}: ${line}`);

    const key = match[1].trim();
    const rawValue = match[2].trim();

    if (!rawValue) {
      const nextLine = lines.slice(idx + 1).find((l) => l.trim() && !l.trim().startsWith('#'));
      const nextTrim = nextLine ? nextLine.trim() : '';
      const isArray = nextTrim.startsWith('- ');
      if (isArray) {
        const arr = [];
        parent.value[key] = arr;
        stack.push({ indent, kind: 'array', value: arr });
      } else {
        const obj = {};
        parent.value[key] = obj;
        stack.push({ indent, kind: 'object', value: obj });
      }
      continue;
    }

    parent.value[key] = parseScalar(rawValue);
  }

  return root;
}

function loadYaml(filePath) {
  return parseYamlSimple(fs.readFileSync(filePath, 'utf8'));
}

function applyStatusUpdateViaTaskMove(projectDir, taskPath, status, reasonText, transcriptRelPath) {
  const reason = String(reasonText || '').trim();
  const comment = reason
    ? `status_update: status=${status}; reason=${reason}`
    : `status_update: status=${status}`;
  return runTaskMove(projectDir, taskPath, {
    status,
    comment,
    attachments: transcriptRelPath,
    author: 'dispatcher',
  });
}

function readStatusDefaults(dispatchCfg) {
  const fallback = {
    in_progress: 'in_progress',
    success: 'done',
    failure: 'blocked',
  };
  const raw = (dispatchCfg && dispatchCfg.defaults) || {};
  const todo = String(raw.status_todo || '').trim();
  const inProgress = String(raw.status_in_progress || '').trim();
  const success = String(raw.status_success || '').trim();
  const failure = String(raw.status_failure || '').trim();
  return {
    todo,
    in_progress: inProgress || fallback.in_progress,
    success: success || fallback.success,
    failure: failure || fallback.failure,
  };
}

function countByColumn(tasks) {
  const counts = new Map();
  for (const t of tasks) {
    const col = t.data.column;
    if (!col) continue;
    counts.set(col, (counts.get(col) || 0) + 1);
  }
  return counts;
}

function canEnterColumn(column, columnsByName, counts) {
  const def = columnsByName.get(column);
  if (!def) return true;
  if (def.wip_limit === '-' || def.wip_limit === undefined) return true;
  const limit = Number(def.wip_limit);
  if (!Number.isFinite(limit)) return true;
  return (counts.get(column) || 0) < limit;
}

function extractWhenThen(rule) {
  const whenObj = (rule && rule.when && typeof rule.when === 'object') ? { ...rule.when } : null;
  const thenFromWhen = whenObj && whenObj.then && typeof whenObj.then === 'object'
    ? { ...whenObj.then }
    : null;
  if (whenObj && Object.prototype.hasOwnProperty.call(whenObj, 'then')) delete whenObj.then;

  const when = whenObj || {
    column: rule.column,
    status: rule.status,
    assignee: rule.assignee,
  };
  const thenCfg = (rule && rule.then && typeof rule.then === 'object')
    ? rule.then
    : (thenFromWhen || {
      status_todo: rule.status_todo,
      column: rule.set_column,
      assignee: rule.set_assignee,
      status_in_progress: rule.status_in_progress,
      status: rule.set_status,
      status_success: rule.status_success,
      status_failure: rule.status_failure,
    });
  return { when, thenCfg };
}

function parseWhenValues(raw) {
  if (raw === undefined || raw === null) return [];
  if (Array.isArray(raw)) {
    return raw
      .map((v) => String(v).trim())
      .filter(Boolean);
  }
  return [String(raw).trim()].filter(Boolean);
}

function whenFieldMatches(taskValue, whenValue) {
  if (whenValue === undefined) return true;
  const values = parseWhenValues(whenValue);
  if (values.length === 0) return true;
  if (values.includes('*')) return true;
  const current = String(taskValue || '').trim();
  return values.includes(current);
}

function ruleMatches(task, rule) {
  const { when } = extractWhenThen(rule);
  if (!whenFieldMatches(task.column, when.column)) return false;
  if (!whenFieldMatches(task.status, when.status)) return false;
  return whenFieldMatches(task.assignee, when.assignee);
}

function applyRule(task, rule, defaults) {
  const { thenCfg } = extractWhenThen(rule);
  const nextStatusInProgress = thenCfg.status_in_progress || defaults.in_progress;
  if (thenCfg.column) task.column = thenCfg.column;
  if (thenCfg.assignee) task.assignee = thenCfg.assignee;
  if (nextStatusInProgress) task.status = nextStatusInProgress;
  else if (thenCfg.status) task.status = thenCfg.status;
  task.updated_at = new Date().toISOString();
}

function statusCfgFromThen(thenCfg, defaults) {
  return {
    todo: String(thenCfg.status_todo || defaults.todo || '').trim(),
    in_progress: String(thenCfg.status_in_progress || defaults.in_progress || '').trim(),
    success: String(thenCfg.status_success || defaults.success || '').trim(),
    failure: String(thenCfg.status_failure || defaults.failure || '').trim(),
  };
}

function resolveStatusCfgForTask(task, rules, defaults) {
  const base = statusCfgFromThen({}, defaults);
  let best = null;
  let bestScore = -1;

  for (const rule of rules || []) {
    const { when, thenCfg } = extractWhenThen(rule);
    const thenAssignee = String(thenCfg.assignee || '').trim();
    if (!thenAssignee || thenAssignee === '-' || thenAssignee === '*') continue;
    if (String(task.assignee || '').trim() !== thenAssignee) continue;

    let score = 2;
    const expectedColumns = parseWhenValues(thenCfg.column || when.column);
    if (expectedColumns.length > 0 && !expectedColumns.includes('*')) {
      const currentColumn = String(task.column || '').trim();
      if (!expectedColumns.includes(currentColumn)) continue;
      score += 2;
    }

    const cfg = statusCfgFromThen(thenCfg, defaults);
    const taskStatus = String(task.status || '').trim().toLowerCase();
    if (cfg.in_progress && taskStatus === cfg.in_progress.toLowerCase()) score += 1;

    if (score > bestScore) {
      bestScore = score;
      best = cfg;
    }
  }

  return best || base;
}

function runAgent(projectDir, agent, taskPath, statusCfg, transcriptPath, sessionTs, completionColumn, launchColumn) {
  const cmd = path.join(__dirname, 'session_new');
  const agentFile = path.join('agents', `${agent}.yaml`);
  const args = ['--board', projectDir, '--agent', agentFile, '--task', taskPath];
  if (transcriptPath) args.push('--transcript', transcriptPath);
  if (sessionTs) args.push('--session-ts', sessionTs);
  if (completionColumn) args.push('--completion-column', completionColumn);
  if (launchColumn) args.push('--column', launchColumn);
  if (statusCfg && statusCfg.todo) args.push('--status-todo', statusCfg.todo);
  if (statusCfg && statusCfg.in_progress) args.push('--status-in-progress', statusCfg.in_progress);
  if (statusCfg && statusCfg.success) args.push('--status-success', statusCfg.success);
  if (statusCfg && statusCfg.failure) args.push('--status-failure', statusCfg.failure);
  const out = spawnSync(cmd, args, {
    cwd: projectDir,
    encoding: 'utf8',
  });
  return out;
}

function runTaskMove(projectDir, taskPath, updates) {
  const cmd = path.join(__dirname, 'task_move');
  const args = [taskPath];
  if (updates && Object.prototype.hasOwnProperty.call(updates, 'column')) args.push('--column', String(updates.column));
  if (updates && Object.prototype.hasOwnProperty.call(updates, 'status')) args.push('--status', String(updates.status));
  if (updates && Object.prototype.hasOwnProperty.call(updates, 'assignee')) args.push('--assignee', String(updates.assignee));
  if (updates && Object.prototype.hasOwnProperty.call(updates, 'comment')) args.push('--comment', String(updates.comment));
  if (updates && Object.prototype.hasOwnProperty.call(updates, 'attachments')) {
    const attachmentValue = updates.attachments;
    const attachmentPath = Array.isArray(attachmentValue) ? attachmentValue[0] : attachmentValue;
    if (attachmentPath !== undefined && attachmentPath !== null) args.push('--attachment', String(attachmentPath));
  }
  if (updates && Object.prototype.hasOwnProperty.call(updates, 'author')) args.push('--author', String(updates.author));
  return spawnSync(cmd, args, {
    cwd: projectDir,
    encoding: 'utf8',
  });
}

function sessionIdForTask(taskFile, task, agent) {
  const column = task.column || 'backlog';
  const taskBase = path.basename(taskFile);
  const taskSlug = taskBase.replace(/\.ya?ml$/i, '');
  return `${agent}__${column}___${taskSlug}`;
}

function sessionIdForTaskAndColumn(taskFile, agent, column) {
  const safeColumn = String(column || 'backlog').trim() || 'backlog';
  const taskBase = path.basename(taskFile);
  const taskSlug = taskBase.replace(/\.ya?ml$/i, '');
  return `${agent}__${safeColumn}___${taskSlug}`;
}

function sessionTimestampUtc() {
  return new Date().toISOString().replace(/[-:]/g, '').replace(/\.\d{3}Z$/, 'Z');
}

function listSessionsForTask(taskFile, agent) {
  const taskBase = path.basename(taskFile);
  const taskSlug = taskBase.replace(/\.ya?ml$/i, '');
  const out = spawnSync('tmux', ['list-sessions', '-F', '#{session_name}\t#{session_created}'], { encoding: 'utf8' });
  if (out.status !== 0) return [];

  const escapedTaskSlug = taskSlug.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  // IMPORTANT SESSION ID INVARIANT:
  // Must stay in sync with bin/session_new and bin/board_show.
  // Strict format: "<agent>__<column>___<task-slug>__YYYYMMDDTHHMMSSZ".
  const taskPattern = new RegExp(`___${escapedTaskSlug}__\\d{8}T\\d{6}Z$`);
  const prefix = String(agent || '').trim() ? `${agent}__` : '';
  return String(out.stdout || '')
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter(Boolean)
    .map((line) => {
      const [name, createdRaw] = line.split('\t');
      const created = Number(createdRaw || 0);
      return { name: String(name || ''), created: Number.isFinite(created) ? created : 0 };
    })
    .filter((entry) => (!prefix || entry.name.startsWith(prefix)) && taskPattern.test(entry.name))
    .sort((a, b) => b.created - a.created);
}

function mostRecentSessionForTask(taskFile, task, agent) {
  const sessions = listSessionsForTask(taskFile, agent);
  if (sessions.length > 0) return sessions[0];
  return { name: sessionIdForTask(taskFile, task, agent), created: 0 };
}

function captureTmux(sessionId, tailLines = 50) {
  const out = spawnSync('tmux', ['capture-pane', '-J', '-t', sessionId, '-p', '-S', '-', '-E', '-'], {
    encoding: 'utf8',
  });
  if (out.status !== 0) return { ok: false, full: '', tail: '', error: `${out.stderr || out.stdout || 'tmux capture failed'}`.trim() };
  const all = (out.stdout || '').split(/\r?\n/);
  const full = all.join('\n').trimEnd();
  const tail = all.slice(-tailLines).join('\n').trimEnd();
  if (!full) return { ok: false, full: '', tail: '', error: 'empty terminal output' };
  return { ok: true, full, tail, error: '' };
}

function ensureDir(p) {
  fs.mkdirSync(p, { recursive: true });
}

function sanitizePathToken(value, fallback) {
  const safe = String(value || '')
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9._-]+/g, '_')
    .replace(/^_+|_+$/g, '');
  return safe || fallback;
}

function transcriptFileForSession(projectDir, taskFile, sessionId) {
  const taskSlug = sanitizePathToken(path.basename(taskFile).replace(/\.ya?ml$/i, ''), 'task');
  const rawSessionSlug = sanitizePathToken(sessionId || 'session', 'session');
  const taskToken = `___${taskSlug}__`;
  const sessionSlug = rawSessionSlug.includes(taskToken)
    ? rawSessionSlug.replace(taskToken, '__')
    : rawSessionSlug;
  const transcriptsDir = path.join(projectDir, 'transcripts', taskSlug);
  ensureDir(transcriptsDir);
  return path.join(transcriptsDir, `${sessionSlug}.txt`);
}

function closeTaskSessionsOnAssigneeChange(projectDir, taskFile) {
  const sessions = listSessionsForTask(taskFile, '');
  let closed = 0;
  let transcriptUpdated = 0;
  for (const session of sessions) {
    const cap = captureTmux(session.name, 50);
    if (cap.ok) {
      const transcriptAbsPath = transcriptFileForSession(projectDir, taskFile, session.name);
      const nextTranscript = cap.full.endsWith('\n') ? cap.full : `${cap.full}\n`;
      const prevTranscript = fs.existsSync(transcriptAbsPath) ? fs.readFileSync(transcriptAbsPath, 'utf8') : null;
      if (prevTranscript === null || prevTranscript !== nextTranscript) {
        fs.writeFileSync(transcriptAbsPath, nextTranscript, 'utf8');
        transcriptUpdated += 1;
      }
    }
    const kill = spawnSync('tmux', ['kill-session', '-t', session.name], { encoding: 'utf8' });
    if (kill.status === 0) closed += 1;
  }
  return { found: sessions.length, closed, transcriptUpdated };
}

function loadEnvFile(envPath) {
  if (!fs.existsSync(envPath)) return;
  const txt = fs.readFileSync(envPath, 'utf8');
  for (const line of txt.split(/\r?\n/)) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('#')) continue;
    const idx = trimmed.indexOf('=');
    if (idx <= 0) continue;
    const key = trimmed.slice(0, idx).trim();
    let val = trimmed.slice(idx + 1).trim();
    if ((val.startsWith('"') && val.endsWith('"')) || (val.startsWith("'") && val.endsWith("'"))) {
      val = val.slice(1, -1);
    }
    if (!(key in process.env)) process.env[key] = val;
  }
}

async function llmTaskStatus({ model, apiKey, baseUrl, endpoint, terminalText, task }) {
  const url = `${baseUrl.replace(/\/$/, '')}${endpoint}`;
  const payload = {
    model,
    temperature: 0,
    response_format: { type: 'json_object' },
    messages: [
      {
        role: 'system',
        content: [
          'You are a strict task-state classifier.',
          'Return JSON only: {"outcome":"success|failure","reason":"<short reason>"}',
          'success means the assignee clearly completed the current task deliverable.',
          'failure means explicit blocker or unrecoverable error.',
          'If signals conflict, return failure.',
          'If completion is not explicit, return failure.',
          'reason must be concise and grounded in the terminal output.',
        ].join('\n'),
      },
      {
        role: 'user',
        content: [
          '<terminal_output>',
          terminalText,
          '</terminal_output>',
          'Classify current outcome as one of: success|failure.',
        ].join('\n\n'),
      },
    ],
  };

  const res = await fetch(url, {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${apiKey}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify(payload),
  });

  if (!res.ok) {
    const body = await res.text();
    throw new Error(`OpenAI request failed: HTTP ${res.status} ${body.slice(0, 200)}`);
  }

  const json = await res.json();
  const content = (((json || {}).choices || [])[0] || {}).message?.content;
  let raw = '';
  if (Array.isArray(content)) {
    raw = content.map((p) => (p && typeof p.text === 'string' ? p.text : '')).join('').trim();
  } else {
    raw = String(content || '').trim();
  }
  let normalized = '';
  let reason = '';
  try {
    const parsed = JSON.parse(raw);
    normalized = String((parsed || {}).outcome || '').trim().toLowerCase();
    reason = String((parsed || {}).reason || '').trim();
  } catch (_e) {
    normalized = '';
    reason = '';
  }
  if (normalized === 'success' || normalized === 'failure') return { outcome: normalized, reason };
  if (raw.toLowerCase().includes('success')) return { outcome: 'success', reason: reason || 'classifier fallback: success keyword' };
  if (raw.toLowerCase().includes('failure')) return { outcome: 'failure', reason: reason || 'classifier fallback: failure keyword' };
  return { outcome: 'failure', reason: reason || 'classifier fallback: ambiguous output' };
}

function transcriptForLlm(fullText, edgeLines = 150) {
  const lines = String(fullText || '').split(/\r?\n/);
  if (lines.length <= edgeLines * 2) return lines.join('\n').trimEnd();
  const head = lines.slice(0, edgeLines).join('\n').trimEnd();
  const tail = lines.slice(-edgeLines).join('\n').trimEnd();
  return `${head}\n\n... [${lines.length - edgeLines * 2} lines omitted] ...\n\n${tail}`.trimEnd();
}

function lastCommentMeta(taskData) {
  const updates = Array.isArray(taskData?.updates) ? taskData.updates : [];
  if (updates.length === 0) return { author: '', timestampMs: null };
  const dated = updates
    .map((comment, idx) => ({
      idx,
      author: String(comment?.author || '').trim(),
      ts: Date.parse(String(comment?.created_at || '')),
    }))
    .filter((entry) => entry.author);
  if (dated.length === 0) return { author: '', timestampMs: null };
  const hasValidDates = dated.some((entry) => Number.isFinite(entry.ts));
  if (!hasValidDates) return { author: dated[dated.length - 1].author, timestampMs: null };
  dated.sort((a, b) => {
    const ta = Number.isFinite(a.ts) ? a.ts : -Infinity;
    const tb = Number.isFinite(b.ts) ? b.ts : -Infinity;
    if (ta !== tb) return ta - tb;
    return a.idx - b.idx;
  });
  const last = dated[dated.length - 1];
  return { author: last.author, timestampMs: Number.isFinite(last.ts) ? last.ts : null };
}

async function evaluateNonNewTasks(projectDir, tasks, defaults, rules) {
  loadEnvFile(path.join(projectDir, '.env'));

  const model = process.env.OPENAI_MODEL || 'gpt-5.4-mini';
  const apiKey = process.env.OPENAI_API_KEY || '';
  const baseUrl = process.env.OPENAI_BASE_URL || 'https://api.openai.com/v1';
  const endpoint = process.env.OPENAI_API_ENDPOINT || '/chat/completions';
  const transcriptCommentMtimeToleranceMs = 2000;

  const updates = [];
  const todoStatus = String(defaults.todo || '').trim().toLowerCase();

  for (const item of tasks) {
    if (String(item.data.status || '').trim().toLowerCase() === todoStatus) continue;
    const agent = item.data.assignee;
    if (!agent || agent === '-') continue;

    const statusCfg = resolveStatusCfgForTask(item.data, rules, defaults);
    const successStatus = String(statusCfg.success || defaults.success);
    const inprogressStatus = String(statusCfg.in_progress || defaults.in_progress);
    const failureStatus = String(statusCfg.failure || defaults.failure);
    const timeoutSec = 300;
    const normalizedStatus = String(item.data.status || '').trim().toLowerCase();
    const normalizedSuccessStatus = String(successStatus || '').trim().toLowerCase();
    const normalizedFailureStatus = String(failureStatus || '').trim().toLowerCase();
    const isTerminalStatus =
      normalizedStatus === normalizedSuccessStatus || normalizedStatus === normalizedFailureStatus;

    const session = mostRecentSessionForTask(item.file, item.data, agent);
    const sessionId = session.name;
    const transcriptAbsPath = transcriptFileForSession(projectDir, item.file, sessionId);
    const transcriptRelPath = path.relative(projectDir, transcriptAbsPath) || 'transcripts';
    const cap = captureTmux(sessionId, 50);
    if (!cap.ok) {
      if (item.data.status !== failureStatus) {
        const moveResult = applyStatusUpdateViaTaskMove(
          projectDir,
          item.file,
          failureStatus,
          `tmux_unavailable:${cap.error}`,
          transcriptRelPath,
        );
        if (moveResult.status !== 0) {
          updates.push({
            file: path.basename(item.file),
            result: 'failure',
            reason: `task_move_error:${(`${moveResult.stdout || ''}${moveResult.stderr || ''}`.trim() || 'task_move failed')}`,
          });
          continue;
        }
        item.data = loadYaml(item.file);
      }
      updates.push({ file: path.basename(item.file), result: 'failure', reason: `tmux_unavailable:${cap.error}` });
      continue;
    }
    const nextTranscript = cap.full.endsWith('\n') ? cap.full : `${cap.full}\n`;
    const hadTranscriptFile = fs.existsSync(transcriptAbsPath);
    const prevTranscript = hadTranscriptFile ? fs.readFileSync(transcriptAbsPath, 'utf8') : null;
    const { author: rawLastCommentAuthor, timestampMs: lastCommentTsMs } = lastCommentMeta(item.data);
    const isLastCommentByDispatcher = rawLastCommentAuthor.toLowerCase() === 'dispatcher';
    const transcriptMtimeMs = hadTranscriptFile ? fs.statSync(transcriptAbsPath).mtimeMs : null;
    const transcriptNotNewerThanLastComment = Number.isFinite(transcriptMtimeMs)
      && Number.isFinite(lastCommentTsMs)
      && transcriptMtimeMs <= (lastCommentTsMs + transcriptCommentMtimeToleranceMs);
    const shouldRefreshWithoutChange = !isLastCommentByDispatcher && transcriptNotNewerThanLastComment;
    const transcriptContentChanged = hadTranscriptFile && prevTranscript !== nextTranscript;
    const shouldInitializeTranscript = !hadTranscriptFile;
    const transcriptChanged = !shouldRefreshWithoutChange && transcriptContentChanged;
    if (shouldInitializeTranscript || transcriptContentChanged) {
      fs.writeFileSync(transcriptAbsPath, nextTranscript, 'utf8');
    }
    if (transcriptChanged) {
      if (item.data.status !== inprogressStatus) {
        const moveResult = applyStatusUpdateViaTaskMove(
          projectDir,
          item.file,
          inprogressStatus,
          'terminal_changed',
          transcriptRelPath,
        );
        if (moveResult.status !== 0) {
          updates.push({
            file: path.basename(item.file),
            result: inprogressStatus,
            reason: `task_move_error:${(`${moveResult.stdout || ''}${moveResult.stderr || ''}`.trim() || 'task_move failed')}`,
          });
          continue;
        }
        item.data = loadYaml(item.file);
      }
      updates.push({
        file: path.basename(item.file),
        result: 'in_progress',
        reason: 'terminal_changed',
      });
      continue;
    }

    if (isTerminalStatus) {
      updates.push({ file: path.basename(item.file), result: normalizedStatus, reason: 'terminal_status_no_transition' });
      continue;
    }

    const st = fs.statSync(transcriptAbsPath);
    const unchangedForSec = (Date.now() - st.mtimeMs) / 1000;
    if (unchangedForSec <= timeoutSec) {
      updates.push({
        file: path.basename(item.file),
        result: inprogressStatus,
        reason: `terminal_unchanged_timeout_not_reached:${Math.floor(unchangedForSec)}s<=${timeoutSec}s`,
      });
      continue;
    }

    if (!apiKey) {
      updates.push({ file: path.basename(item.file), result: inprogressStatus, reason: 'missing_openai_api_key' });
      continue;
    }

    let outcome = 'failure';
    let outcomeReason = '';
    try {
      const transcriptExcerpt = transcriptForLlm(cap.full, 150);
      const llmResult = await llmTaskStatus({ model, apiKey, baseUrl, endpoint, terminalText: transcriptExcerpt, task: item.data });
      outcome = llmResult.outcome;
      outcomeReason = llmResult.reason;
    } catch (e) {
      outcome = 'failure';
      outcomeReason = `llm_error:${String(e.message || e)}`;
      updates.push({ file: path.basename(item.file), result: 'failure', reason: `llm_error:${String(e.message || e)}` });
    }

    if (outcome === 'success' && item.data.status !== successStatus) {
      const moveResult = applyStatusUpdateViaTaskMove(
        projectDir,
        item.file,
        successStatus,
        outcomeReason,
        transcriptRelPath,
      );
      if (moveResult.status !== 0) {
        updates.push({
          file: path.basename(item.file),
          result: 'failure',
          reason: `task_move_error:${(`${moveResult.stdout || ''}${moveResult.stderr || ''}`.trim() || 'task_move failed')}`,
        });
        continue;
      }
      item.data = loadYaml(item.file);
    } else if (outcome === 'failure' && item.data.status !== failureStatus) {
      const moveResult = applyStatusUpdateViaTaskMove(
        projectDir,
        item.file,
        failureStatus,
        outcomeReason,
        transcriptRelPath,
      );
      if (moveResult.status !== 0) {
        updates.push({
          file: path.basename(item.file),
          result: 'failure',
          reason: `task_move_error:${(`${moveResult.stdout || ''}${moveResult.stderr || ''}`.trim() || 'task_move failed')}`,
        });
        continue;
      }
      item.data = loadYaml(item.file);
    }

    if (!updates.find((u) => u.file === path.basename(item.file) && u.result === 'failure')) {
      updates.push({ file: path.basename(item.file), result: outcome, reason: 'llm' });
    }
  }

  return updates;
}

function acquireLock(projectDir) {
  const safe = path.resolve(projectDir).replace(/[^A-Za-z0-9_.-]/g, '_');
  const lockDir = path.join(os.tmpdir(), `code-conveyor-dispatch.lock.${safe}`);
  const ownerFile = path.join(lockDir, 'owner.json');

  function isPidRunning(pid) {
    try {
      process.kill(pid, 0);
      return true;
    } catch (_e) {
      return false;
    }
  }

  try {
    fs.mkdirSync(lockDir);
  } catch (e) {
    if (e.code !== 'EEXIST') throw e;
    try {
      const owner = JSON.parse(fs.readFileSync(ownerFile, 'utf8'));
      if (owner && Number.isInteger(owner.pid) && isPidRunning(owner.pid)) {
        return null;
      }
    } catch (_e) {
      // ignore malformed owner file
    }
    fs.rmSync(lockDir, { recursive: true, force: true });
    fs.mkdirSync(lockDir);
  }

  fs.writeFileSync(ownerFile, JSON.stringify({ pid: process.pid, started_at: new Date().toISOString() }));
  return () => fs.rmSync(lockDir, { recursive: true, force: true });
}

async function main() {
  const argv = process.argv.slice(2);
  let projectDir = process.cwd();
  for (let i = 0; i < argv.length; i += 1) {
    const token = argv[i];
    if (token === '--board' || token === '--dir') {
      const next = argv[i + 1];
      if (!next) throw new Error(`Missing value after ${token}`);
      projectDir = path.resolve(next);
      i += 1;
      continue;
    }
    if (token.startsWith('--board=')) {
      projectDir = path.resolve(token.slice('--board='.length));
      continue;
    }
    if (token.startsWith('--dir=')) {
      projectDir = path.resolve(token.slice('--dir='.length));
      continue;
    }
    if (token === '--help' || token === '-h') {
      console.log('Usage: dispatch [--board <path>]');
      return;
    }
    throw new Error(`Unknown argument: ${token}`);
  }

  const releaseLock = acquireLock(projectDir);
  if (!releaseLock) {
    console.log('Skipped: bin/dispatch is already running');
    return;
  }

  try {
    const dispatchPath = path.join(projectDir, 'dispatch.yaml');
    const tasksDir = path.join(projectDir, 'tasks');

    if (!fs.existsSync(dispatchPath)) throw new Error(`dispatch.yaml not found: ${dispatchPath}`);
    if (!fs.existsSync(tasksDir)) throw new Error(`tasks dir not found: ${tasksDir}`);

    const dispatch = loadYaml(dispatchPath);
    const columns = (dispatch.board && dispatch.board.columns) || [];
    const rules = dispatch.rules || [];
    const columnsByName = new Map(columns.map((c) => [c.name, c]));

    const taskFiles = fs.readdirSync(tasksDir)
      .filter((f) => /\.ya?ml$/i.test(f))
      .sort();

    const tasks = taskFiles.map((file) => {
      const full = path.join(tasksDir, file);
      const data = loadYaml(full);
      if (!data.column && data.stage) data.column = data.stage;
      if (!data.column) data.column = 'backlog';
      return { file: full, data };
    });

    const statusDefaults = readStatusDefaults(dispatch);
    const taskStatusChecks = await evaluateNonNewTasks(projectDir, tasks, statusDefaults, rules);

    const counts = countByColumn(tasks);
    const moved = [];
    const skipped = [];
    const launched = [];
    const taskMoveErrors = [];

    for (const rule of rules) {
      for (const item of tasks) {
        if (!ruleMatches(item.data, rule)) continue;
        const fromColumn = item.data.column || 'backlog';
        const { thenCfg } = extractWhenThen(rule);
        const toColumn = thenCfg.column || fromColumn;
        const launchAgent = (thenCfg.assignee && thenCfg.assignee !== '-')
          ? thenCfg.assignee
          : '';

        if (toColumn && !canEnterColumn(toColumn, columnsByName, counts)) {
          skipped.push({ file: path.basename(item.file), reason: `WIP limit reached in column ${toColumn}` });
          continue;
        }

        const nextTask = { ...item.data };
        applyRule(nextTask, rule, statusDefaults);

        if (launchAgent) {
          const launchStatuses = statusCfgFromThen(thenCfg, statusDefaults);
          const sessionTs = sessionTimestampUtc();
          const launchColumn = nextTask.column || toColumn || fromColumn;
          const sessionId = `${sessionIdForTaskAndColumn(item.file, launchAgent, launchColumn)}__${sessionTs}`;
          const transcriptAbsPath = transcriptFileForSession(projectDir, item.file, sessionId);
          const transcriptRelPath = path.relative(projectDir, transcriptAbsPath) || 'transcripts';
          const result = runAgent(
            projectDir,
            launchAgent,
            item.file,
            launchStatuses,
            transcriptRelPath,
            sessionTs,
            launchColumn,
            launchColumn,
          );
          launched.push({
            file: path.basename(item.file),
            agent: launchAgent,
            ok: result.status === 0,
            output: `${result.stdout || ''}${result.stderr || ''}`.trim(),
          });
          if (result.status !== 0) continue;
        }

        const moveResult = runTaskMove(projectDir, item.file, {
          column: nextTask.column,
          status: nextTask.status,
          assignee: nextTask.assignee,
          author: 'dispatcher',
        });
        if (moveResult.status !== 0) {
          taskMoveErrors.push({
            file: path.basename(item.file),
            output: `${moveResult.stdout || ''}${moveResult.stderr || ''}`.trim() || 'task_move failed',
          });
          continue;
        }
        item.data = nextTask;
        moved.push(path.basename(item.file));

        if (fromColumn) counts.set(fromColumn, Math.max(0, (counts.get(fromColumn) || 0) - 1));
        if (toColumn) counts.set(toColumn, (counts.get(toColumn) || 0) + 1);
      }
    }

    console.log(`Moved: ${moved.length}`);
    for (const file of moved) console.log(`- ${file}`);
    if (taskStatusChecks.length > 0) {
      console.log(`Task status checks: ${taskStatusChecks.length}`);
      for (const s of taskStatusChecks) {
        console.log(`- ${s.file}: ${s.result} (${s.reason})`);
      }
    }
    if (skipped.length > 0) {
      console.log(`Skipped: ${skipped.length}`);
      for (const s of skipped) console.log(`- ${s.file}: ${s.reason}`);
    }
    if (launched.length > 0) {
      console.log(`Launched: ${launched.length}`);
      for (const l of launched) {
        console.log(`- ${l.file}: agent=${l.agent}, ok=${l.ok}`);
        if (!l.ok && l.output) console.log(`  ${l.output.replace(/\n/g, '\n  ')}`);
      }
    }
    if (taskMoveErrors.length > 0) {
      console.log(`Task move errors: ${taskMoveErrors.length}`);
      for (const e of taskMoveErrors) {
        console.log(`- ${e.file}: ${e.output.replace(/\n/g, '\n  ')}`);
      }
    }
  } finally {
    releaseLock();
  }
}

main().catch((err) => {
  console.error(err.message);
  process.exit(1);
});

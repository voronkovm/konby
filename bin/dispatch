#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const os = require('os');
const { spawnSync } = require('child_process');
const { listAllKonbySessions, listTaskSessions, parseKonbySessionName, sessionIdPrefix } = require('../lib/tmux_sessions');
const { resolveBoardDir } = require('../lib/workdir');
const { loadYaml } = require('../lib/yaml');
const {
  applyRule,
  canEnterColumn,
  countByColumn,
  extractWhenThen,
  lastCommentMeta,
  parseDispatchArgs,
  parseLlmOutcomeResponse,
  readStatusDefaults,
  resolveStatusCfgForTask,
  ruleMatches,
  statusCfgFromThen,
  transcriptForLlm,
} = require('../lib/dispatch');
const { loadEnvFile } = require('../lib/env');
const { transcriptPathForSession } = require('../lib/transcript');
const { sessionTimestampUtc } = require('../lib/session_new');

function applyStatusUpdateViaTaskMove(projectDir, taskPath, status, reasonText, transcriptRelPath) {
  const reason = String(reasonText || '').trim();
  const comment = reason
    ? `status_update: status=${status}; reason=${reason}`
    : `status_update: status=${status}`;
  return runTaskMove(projectDir, taskPath, {
    status,
    comment,
    attachments: transcriptRelPath,
    author: 'dispatcher',
  });
}

function runAgent(projectDir, agent, taskPath, statusCfg, transcriptPath, sessionTs, completionColumn) {
  const cmd = path.join(__dirname, 'session_new');
  const agentFile = path.join('agents', `${agent}.yaml`);
  const args = ['--board', projectDir, '--agent', agentFile, '--task', taskPath];
  if (transcriptPath) args.push('--transcript', transcriptPath);
  if (sessionTs) args.push('--session-ts', sessionTs);
  if (completionColumn) args.push('--completion-column', completionColumn);
  if (statusCfg && statusCfg.todo) args.push('--status-todo', statusCfg.todo);
  if (statusCfg && statusCfg.in_progress) args.push('--status-in-progress', statusCfg.in_progress);
  if (statusCfg && statusCfg.success) args.push('--status-success', statusCfg.success);
  if (statusCfg && statusCfg.failure) args.push('--status-failure', statusCfg.failure);
  const out = spawnSync(cmd, args, {
    cwd: projectDir,
    encoding: 'utf8',
  });
  return out;
}

function tmuxSessionExists(sessionId) {
  const out = spawnSync('tmux', ['has-session', '-t', sessionId], { encoding: 'utf8' });
  return out.status === 0;
}

function runTaskMove(projectDir, taskPath, updates) {
  const cmd = path.join(__dirname, 'task_move');
  const args = [taskPath];
  if (updates && Object.prototype.hasOwnProperty.call(updates, 'column')) args.push('--column', String(updates.column));
  if (updates && Object.prototype.hasOwnProperty.call(updates, 'status')) args.push('--status', String(updates.status));
  if (updates && Object.prototype.hasOwnProperty.call(updates, 'assignee')) args.push('--assignee', String(updates.assignee));
  if (updates && Object.prototype.hasOwnProperty.call(updates, 'comment')) args.push('--comment', String(updates.comment));
  if (updates && Object.prototype.hasOwnProperty.call(updates, 'attachments')) {
    const attachmentValue = updates.attachments;
    const attachmentPath = Array.isArray(attachmentValue) ? attachmentValue[0] : attachmentValue;
    if (attachmentPath !== undefined && attachmentPath !== null) args.push('--attachment', String(attachmentPath));
  }
  if (updates && Object.prototype.hasOwnProperty.call(updates, 'author')) args.push('--author', String(updates.author));
  return spawnSync(cmd, args, {
    cwd: projectDir,
    encoding: 'utf8',
  });
}

function mostRecentSessionForTask(taskFile, task, agent) {
  const sessions = listTaskSessions(taskFile, { agent });
  if (sessions.length > 0) return sessions[0];
  return { name: sessionIdPrefix(agent, taskFile), created: 0 };
}

function captureTmux(sessionId, tailLines = 50) {
  const out = spawnSync('tmux', ['capture-pane', '-J', '-t', sessionId, '-p', '-S', '-', '-E', '-'], {
    encoding: 'utf8',
  });
  if (out.status !== 0) return { ok: false, full: '', tail: '', error: `${out.stderr || out.stdout || 'tmux capture failed'}`.trim() };
  const all = (out.stdout || '').split(/\r?\n/);
  const full = all.join('\n').trimEnd();
  const tail = all.slice(-tailLines).join('\n').trimEnd();
  if (!full) return { ok: false, full: '', tail: '', error: 'empty terminal output' };
  return { ok: true, full, tail, error: '' };
}


async function llmTaskStatus({ model, apiKey, baseUrl, endpoint, terminalText, task }) {
  const url = `${baseUrl.replace(/\/$/, '')}${endpoint}`;
  const payload = {
    model,
    temperature: 0,
    response_format: { type: 'json_object' },
    messages: [
      {
        role: 'system',
        content: [
          'You are a strict task-state classifier.',
          'Return JSON only: {"outcome":"success|failure","reason":"<short reason>"}',
          'success means the assignee clearly completed the current task deliverable.',
          'failure means explicit blocker or unrecoverable error.',
          'If signals conflict, return failure.',
          'If completion is not explicit, return failure.',
          'reason must be concise and grounded in the terminal output.',
        ].join('\n'),
      },
      {
        role: 'user',
        content: [
          '<terminal_output>',
          terminalText,
          '</terminal_output>',
          'Classify current outcome as one of: success|failure.',
        ].join('\n\n'),
      },
    ],
  };

  const res = await fetch(url, {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${apiKey}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify(payload),
  });

  if (!res.ok) {
    const body = await res.text();
    throw new Error(`OpenAI request failed: HTTP ${res.status} ${body.slice(0, 200)}`);
  }

  const json = await res.json();
  const content = (((json || {}).choices || [])[0] || {}).message?.content;
  let raw = '';
  if (Array.isArray(content)) {
    raw = content.map((p) => (p && typeof p.text === 'string' ? p.text : '')).join('').trim();
  } else {
    raw = String(content || '').trim();
  }
  return parseLlmOutcomeResponse(raw);
}

async function evaluateNonNewTasks(projectDir, tasks, defaults, rules) {
  loadEnvFile(path.join(projectDir, '.env'));

  const model = process.env.OPENAI_MODEL || 'gpt-5.4-mini';
  const apiKey = process.env.OPENAI_API_KEY || '';
  const baseUrl = process.env.OPENAI_BASE_URL || 'https://api.openai.com/v1';
  const endpoint = process.env.OPENAI_API_ENDPOINT || '/chat/completions';
  const transcriptCommentMtimeToleranceMs = 2000;

  const updates = [];
  const todoStatus = String(defaults.todo || '').trim().toLowerCase();

  for (const item of tasks) {
    if (String(item.data.status || '').trim().toLowerCase() === todoStatus) continue;
    const agent = item.data.assignee;
    if (!agent || agent === '-') continue;

    const statusCfg = resolveStatusCfgForTask(item.data, rules, defaults);
    const successStatus = String(statusCfg.success || defaults.success);
    const inprogressStatus = String(statusCfg.in_progress || defaults.in_progress);
    const failureStatus = String(statusCfg.failure || defaults.failure);
    const timeoutSec = 300;
    const normalizedStatus = String(item.data.status || '').trim().toLowerCase();
    const normalizedSuccessStatus = String(successStatus || '').trim().toLowerCase();
    const normalizedFailureStatus = String(failureStatus || '').trim().toLowerCase();
    const normalizedInprogressStatus = String(inprogressStatus || '').trim().toLowerCase();
    const isTerminalStatus =
      normalizedStatus === normalizedSuccessStatus || normalizedStatus === normalizedFailureStatus;

    const session = mostRecentSessionForTask(item.file, item.data, agent);
    const sessionId = session.name;
    const transcriptAbsPath = transcriptPathForSession(projectDir, item.file, sessionId);
    fs.mkdirSync(path.dirname(transcriptAbsPath), { recursive: true });
    const transcriptRelPath = path.relative(projectDir, transcriptAbsPath) || 'transcripts';
    const cap = captureTmux(sessionId, 50);
    if (!cap.ok) {
      if (normalizedStatus !== normalizedInprogressStatus) continue;
      if (item.data.status !== failureStatus) {
        const moveResult = applyStatusUpdateViaTaskMove(
          projectDir,
          item.file,
          failureStatus,
          `tmux_unavailable:${cap.error}`,
          transcriptRelPath,
        );
        if (moveResult.status !== 0) {
          updates.push({
            file: path.basename(item.file),
            result: 'failure',
            reason: `task_move_error:${(`${moveResult.stdout || ''}${moveResult.stderr || ''}`.trim() || 'task_move failed')}`,
          });
          continue;
        }
        item.data = loadYaml(item.file);
      }
      updates.push({ file: path.basename(item.file), result: 'failure', reason: `tmux_unavailable:${cap.error}` });
      continue;
    }
    const nextTranscript = cap.full.endsWith('\n') ? cap.full : `${cap.full}\n`;
    const hadTranscriptFile = fs.existsSync(transcriptAbsPath);
    const prevTranscript = hadTranscriptFile ? fs.readFileSync(transcriptAbsPath, 'utf8') : null;
    const { author: rawLastCommentAuthor, timestampMs: lastCommentTsMs } = lastCommentMeta(item.data);
    const isLastCommentByDispatcher = rawLastCommentAuthor.toLowerCase() === 'dispatcher';
    const transcriptMtimeMs = hadTranscriptFile ? fs.statSync(transcriptAbsPath).mtimeMs : null;
    const transcriptNotNewerThanLastComment = Number.isFinite(transcriptMtimeMs)
      && Number.isFinite(lastCommentTsMs)
      && transcriptMtimeMs <= (lastCommentTsMs + transcriptCommentMtimeToleranceMs);
    const shouldRefreshWithoutChange = !isLastCommentByDispatcher && transcriptNotNewerThanLastComment;
    const transcriptContentChanged = hadTranscriptFile && prevTranscript !== nextTranscript;
    const shouldInitializeTranscript = !hadTranscriptFile;
    const transcriptChanged = !shouldRefreshWithoutChange && transcriptContentChanged;
    if (shouldInitializeTranscript || transcriptContentChanged) {
      fs.writeFileSync(transcriptAbsPath, nextTranscript, 'utf8');
    }
    if (transcriptChanged) {
      if (item.data.status !== inprogressStatus) {
        const moveResult = applyStatusUpdateViaTaskMove(
          projectDir,
          item.file,
          inprogressStatus,
          'terminal_changed',
          transcriptRelPath,
        );
        if (moveResult.status !== 0) {
          updates.push({
            file: path.basename(item.file),
            result: inprogressStatus,
            reason: `task_move_error:${(`${moveResult.stdout || ''}${moveResult.stderr || ''}`.trim() || 'task_move failed')}`,
          });
          continue;
        }
        item.data = loadYaml(item.file);
      }
      updates.push({
        file: path.basename(item.file),
        result: 'in_progress',
        reason: 'terminal_changed',
      });
      continue;
    }

    if (isTerminalStatus) {
      updates.push({ file: path.basename(item.file), result: normalizedStatus, reason: 'terminal_status_no_transition' });
      continue;
    }

    const st = fs.statSync(transcriptAbsPath);
    const unchangedForSec = (Date.now() - st.mtimeMs) / 1000;
    if (unchangedForSec <= timeoutSec) {
      updates.push({
        file: path.basename(item.file),
        result: inprogressStatus,
        reason: `terminal_unchanged_timeout_not_reached:${Math.floor(unchangedForSec)}s<=${timeoutSec}s`,
      });
      continue;
    }

    if (!apiKey) {
      updates.push({ file: path.basename(item.file), result: inprogressStatus, reason: 'missing_openai_api_key' });
      continue;
    }

    let outcome = 'failure';
    let outcomeReason = '';
    try {
      const transcriptExcerpt = transcriptForLlm(cap.full, 150);
      const llmResult = await llmTaskStatus({ model, apiKey, baseUrl, endpoint, terminalText: transcriptExcerpt, task: item.data });
      outcome = llmResult.outcome;
      outcomeReason = llmResult.reason;
    } catch (e) {
      outcome = 'failure';
      outcomeReason = `llm_error:${String(e.message || e)}`;
      updates.push({ file: path.basename(item.file), result: 'failure', reason: `llm_error:${String(e.message || e)}` });
    }

    if (outcome === 'success' && item.data.status !== successStatus) {
      const moveResult = applyStatusUpdateViaTaskMove(
        projectDir,
        item.file,
        successStatus,
        outcomeReason,
        transcriptRelPath,
      );
      if (moveResult.status !== 0) {
        updates.push({
          file: path.basename(item.file),
          result: 'failure',
          reason: `task_move_error:${(`${moveResult.stdout || ''}${moveResult.stderr || ''}`.trim() || 'task_move failed')}`,
        });
        continue;
      }
      item.data = loadYaml(item.file);
    } else if (outcome === 'failure' && item.data.status !== failureStatus) {
      const moveResult = applyStatusUpdateViaTaskMove(
        projectDir,
        item.file,
        failureStatus,
        outcomeReason,
        transcriptRelPath,
      );
      if (moveResult.status !== 0) {
        updates.push({
          file: path.basename(item.file),
          result: 'failure',
          reason: `task_move_error:${(`${moveResult.stdout || ''}${moveResult.stderr || ''}`.trim() || 'task_move failed')}`,
        });
        continue;
      }
      item.data = loadYaml(item.file);
    }

    if (!updates.find((u) => u.file === path.basename(item.file) && u.result === 'failure')) {
      updates.push({ file: path.basename(item.file), result: outcome, reason: 'llm' });
    }
  }

  return updates;
}

function closeOrphanedSessions(projectDir, tasks) {
  const allSessions = listAllKonbySessions();
  if (allSessions.length === 0) return [];

  const taskBySlug = new Map();
  for (const item of tasks) {
    const slug = path.basename(item.file).replace(/\.ya?ml$/i, '');
    taskBySlug.set(slug, item);
  }

  const results = [];
  for (const session of allSessions) {
    const parsed = parseKonbySessionName(session.name);
    if (!parsed) continue;

    const item = taskBySlug.get(parsed.taskSlug);
    if (!item) continue;

    const currentAssignee = String(item.data.assignee || '').trim();
    if (currentAssignee === parsed.agent) continue;

    const cap = captureTmux(session.name, 50);
    if (cap.ok) {
      const transcriptAbsPath = transcriptPathForSession(projectDir, item.file, session.name);
      fs.mkdirSync(path.dirname(transcriptAbsPath), { recursive: true });
      const nextTranscript = cap.full.endsWith('\n') ? cap.full : `${cap.full}\n`;
      const prevTranscript = fs.existsSync(transcriptAbsPath) ? fs.readFileSync(transcriptAbsPath, 'utf8') : null;
      if (prevTranscript === null || prevTranscript !== nextTranscript) {
        fs.writeFileSync(transcriptAbsPath, nextTranscript, 'utf8');
      }
    }

    spawnSync('tmux', ['kill-session', '-t', session.name], { encoding: 'utf8' });
    results.push({
      session: session.name,
      task: path.basename(item.file),
      agent: parsed.agent,
      assignee: currentAssignee,
    });
  }

  return results;
}

function acquireLock(projectDir) {
  const safe = path.resolve(projectDir).replace(/[^A-Za-z0-9_.-]/g, '_');
  const lockDir = path.join(os.tmpdir(), `code-conveyor-dispatch.lock.${safe}`);
  const ownerFile = path.join(lockDir, 'owner.json');

  function isPidRunning(pid) {
    try {
      process.kill(pid, 0);
      return true;
    } catch (_e) {
      return false;
    }
  }

  try {
    fs.mkdirSync(lockDir);
  } catch (e) {
    if (e.code !== 'EEXIST') throw e;
    try {
      const owner = JSON.parse(fs.readFileSync(ownerFile, 'utf8'));
      if (owner && Number.isInteger(owner.pid) && isPidRunning(owner.pid)) {
        return null;
      }
    } catch (_e) {
      // ignore malformed owner file
    }
    fs.rmSync(lockDir, { recursive: true, force: true });
    fs.mkdirSync(lockDir);
  }

  fs.writeFileSync(ownerFile, JSON.stringify({ pid: process.pid, started_at: new Date().toISOString() }));
  return () => fs.rmSync(lockDir, { recursive: true, force: true });
}

async function main() {
  const { help, boardPathHint } = parseDispatchArgs(process.argv.slice(2));
  if (help) {
    console.log('Usage: dispatch [--board <path>]');
    return;
  }
  const projectDir = resolveBoardDir({ startDir: process.env.PWD || process.cwd(), pathHint: boardPathHint });

  const releaseLock = acquireLock(projectDir);
  if (!releaseLock) {
    console.log('Skipped: bin/dispatch is already running');
    return;
  }

  try {
    const dispatchPath = path.join(projectDir, 'dispatch.yaml');
    const tasksDir = path.join(projectDir, 'tasks');

    if (!fs.existsSync(dispatchPath)) throw new Error(`dispatch.yaml not found: ${dispatchPath}`);
    if (!fs.existsSync(tasksDir)) throw new Error(`tasks dir not found: ${tasksDir}`);

    const dispatch = loadYaml(dispatchPath);
    const columns = (dispatch.board && dispatch.board.columns) || [];
    const rules = dispatch.rules || [];
    const columnsByName = new Map(columns.map((c) => [c.name, c]));

    const taskFiles = fs.readdirSync(tasksDir)
      .filter((f) => /\.ya?ml$/i.test(f))
      .sort();

    const tasks = taskFiles.map((file) => {
      const full = path.join(tasksDir, file);
      const data = loadYaml(full);
      if (!data.column && data.stage) data.column = data.stage;
      if (!data.column) data.column = 'backlog';
      return { file: full, data };
    });

    const statusDefaults = readStatusDefaults(dispatch);
    const taskStatusChecks = await evaluateNonNewTasks(projectDir, tasks, statusDefaults, rules);

    const counts = countByColumn(tasks);
    const moved = [];
    const skipped = [];
    const launched = [];
    const taskMoveErrors = [];

    for (const rule of rules) {
      for (const item of tasks) {
        if (!ruleMatches(item.data, rule)) continue;
        const fromColumn = item.data.column || 'backlog';
        const { thenCfg } = extractWhenThen(rule);
        const toColumn = thenCfg.column || fromColumn;
        const launchAgent = (thenCfg.assignee && thenCfg.assignee !== '-')
          ? thenCfg.assignee
          : '';

        if (toColumn && !canEnterColumn(toColumn, columnsByName, counts)) {
          skipped.push({ file: path.basename(item.file), reason: `WIP limit reached in column ${toColumn}` });
          continue;
        }

        const nextTask = { ...item.data };
        applyRule(nextTask, rule, statusDefaults);

        if (launchAgent) {
          const launchStatuses = statusCfgFromThen(thenCfg, statusDefaults);
          const sessionTs = sessionTimestampUtc();
          const launchColumn = nextTask.column || toColumn || fromColumn;
          const sessionId = `${sessionIdPrefix(launchAgent, item.file)}__${sessionTs}`;
          const transcriptAbsPath = transcriptPathForSession(projectDir, item.file, sessionId);
    fs.mkdirSync(path.dirname(transcriptAbsPath), { recursive: true });
          const transcriptRelPath = path.relative(projectDir, transcriptAbsPath) || 'transcripts';
          const result = runAgent(
            projectDir,
            launchAgent,
            item.file,
            launchStatuses,
            transcriptRelPath,
            sessionTs,
            launchColumn,
          );
          launched.push({
            file: path.basename(item.file),
            agent: launchAgent,
            ok: result.status === 0,
            output: `${result.stdout || ''}${result.stderr || ''}`.trim(),
          });
          if (result.status !== 0) continue;
          if (!tmuxSessionExists(sessionId)) {
            launched[launched.length - 1].ok = false;
            launched[launched.length - 1].output = [
              launched[launched.length - 1].output,
              `tmux session not running after launch: ${sessionId}`,
            ].filter(Boolean).join('\n');
            continue;
          }
        }

        const moveResult = runTaskMove(projectDir, item.file, {
          column: nextTask.column,
          status: nextTask.status,
          assignee: nextTask.assignee,
          author: 'dispatcher',
        });
        if (moveResult.status !== 0) {
          taskMoveErrors.push({
            file: path.basename(item.file),
            output: `${moveResult.stdout || ''}${moveResult.stderr || ''}`.trim() || 'task_move failed',
          });
          continue;
        }
        item.data = nextTask;
        moved.push(path.basename(item.file));

        if (fromColumn) counts.set(fromColumn, Math.max(0, (counts.get(fromColumn) || 0) - 1));
        if (toColumn) counts.set(toColumn, (counts.get(toColumn) || 0) + 1);
      }
    }

    const orphanedClosed = closeOrphanedSessions(projectDir, tasks);

    if (orphanedClosed.length > 0) {
      console.log(`Orphaned sessions closed: ${orphanedClosed.length}`);
      for (const r of orphanedClosed) {
        console.log(`- ${r.session}: task=${r.task}, agent=${r.agent}, current_assignee=${r.assignee}`);
      }
    }
    console.log(`Moved: ${moved.length}`);
    for (const file of moved) console.log(`- ${file}`);
    if (taskStatusChecks.length > 0) {
      console.log(`Task status checks: ${taskStatusChecks.length}`);
      for (const s of taskStatusChecks) {
        console.log(`- ${s.file}: ${s.result} (${s.reason})`);
      }
    }
    if (skipped.length > 0) {
      console.log(`Skipped: ${skipped.length}`);
      for (const s of skipped) console.log(`- ${s.file}: ${s.reason}`);
    }
    if (launched.length > 0) {
      console.log(`Launched: ${launched.length}`);
      for (const l of launched) {
        console.log(`- ${l.file}: agent=${l.agent}, ok=${l.ok}`);
        if (!l.ok && l.output) console.log(`  ${l.output.replace(/\n/g, '\n  ')}`);
      }
    }
    if (taskMoveErrors.length > 0) {
      console.log(`Task move errors: ${taskMoveErrors.length}`);
      for (const e of taskMoveErrors) {
        console.log(`- ${e.file}: ${e.output.replace(/\n/g, '\n  ')}`);
      }
    }
  } finally {
    releaseLock();
  }
}

main().catch((err) => {
  console.error(err.message);
  process.exit(1);
});

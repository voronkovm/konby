#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { resolveBoardDir } = require('../lib/workdir');
const {
  buildTask,
  deriveTaskIdentityFromNumber,
  generateLocalSlug,
  nextTaskNumberFromFileNames,
  normalizeTaskType,
  parseArgs,
  parseGeneratedTaskMeta,
  parseYamlSimple,
  sanitizeFileNamePart,
  taskYamlContent,
  usage,
  validate,
} = require('../lib/task_add');
const { loadEnvFile } = require('../lib/env');

function nextTaskNumber(dirPath) {
  if (!fs.existsSync(dirPath)) return 1;
  return nextTaskNumberFromFileNames(fs.readdirSync(dirPath));
}

async function generateTaskMetaWithOpenAI(text, allowedTypes) {
  const apiKey = process.env.OPENAI_API_KEY;
  if (!apiKey) return { slug: generateLocalSlug(text, 5), type: 'task' };

  const baseUrl = (process.env.OPENAI_BASE_URL || 'https://api.openai.com/v1').replace(/\/+$/, '');
  const endpoint = process.env.OPENAI_API_ENDPOINT || '/chat/completions';
  const model = process.env.OPENAI_MODEL || 'gpt-5.4-mini';
  const url = endpoint.startsWith('http') ? endpoint : `${baseUrl}${endpoint.startsWith('/') ? endpoint : `/${endpoint}`}`;

  const response = await fetch(url, {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${apiKey}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({
      model,
      temperature: 0,
      messages: [
        {
          role: 'system',
          content: `Translate the task title to English and classify its type. Respond only as JSON: {"slug":"...","type":"..."}. Allowed types: ${allowedTypes.join(', ')}. Slug: lowercase latin letters, numbers, hyphens, max 5 words.`,
        },
        {
          role: 'user',
          content: `Task title: ${text}`,
        },
      ],
    }),
  });

  try {
    if (!response.ok) {
      return { slug: generateLocalSlug(text, 5), type: 'task' };
    }

    const data = await response.json();
    const content =
      data &&
      data.choices &&
      data.choices[0] &&
      data.choices[0].message &&
      typeof data.choices[0].message.content === 'string'
        ? data.choices[0].message.content
        : '';

    return parseGeneratedTaskMeta(content, text, allowedTypes);
  } catch (_) {
    return { slug: generateLocalSlug(text, 5), type: 'task' };
  }
}

async function writeTaskFile(dirPath, obj, force, schema) {
  if (!obj.id || typeof obj.id !== 'string' || !obj.id.trim()) {
    obj.id = deriveTaskIdentityFromNumber(obj, nextTaskNumber(dirPath)).id;
  }

  fs.mkdirSync(dirPath, { recursive: true });
  const filePath = path.join(dirPath, `${sanitizeFileNamePart(obj.id)}.yaml`);

  if (!force && fs.existsSync(filePath)) {
    throw new Error(`Task file already exists: ${filePath}. Use --force true to overwrite.`);
  }

  fs.writeFileSync(filePath, taskYamlContent(obj, schema), 'utf8');
  return filePath;
}

async function main() {
  const args = parseArgs(process.argv.slice(2));
  const boardDir = resolveBoardDir({
    startDir: process.env.PWD || process.cwd(),
    pathHint: args.values.board || args.values.dir,
  });
  const projectDir = boardDir;
  loadEnvFile(path.join(projectDir, '.env'));
  const schemaPath = path.resolve(
    projectDir,
    args.values.schema || 'task.schema.yaml',
  );
  const targetDir = path.resolve(projectDir, args.values.tasks || args.values.file || 'tasks');
  const argsForTask = {
    ...args,
    values: { ...args.values },
  };
  delete argsForTask.values.board;
  delete argsForTask.values.dir;
  delete argsForTask.values.schema;
  delete argsForTask.values.tasks;
  delete argsForTask.values.file;

  if (args.help) {
    const schema = fs.existsSync(schemaPath)
      ? parseYamlSimple(fs.readFileSync(schemaPath, 'utf8'))
      : { properties: {} };
    console.log(usage(schema));
    process.exit(0);
  }

  if (!fs.existsSync(schemaPath)) {
    throw new Error(`Schema not found: ${schemaPath}`);
  }

  const schema = parseYamlSimple(fs.readFileSync(schemaPath, 'utf8'));
  const task = buildTask(argsForTask, schema);
  const schemaTypes =
    schema &&
    schema.properties &&
    schema.properties.type &&
    Array.isArray(schema.properties.type.enum)
      ? schema.properties.type.enum
      : ['task'];
  const meta = await generateTaskMetaWithOpenAI(task.title || '', schemaTypes);

  const userProvidedType =
    Object.prototype.hasOwnProperty.call(argsForTask.values, 'type') ||
    argsForTask.set.some((pair) => pair.startsWith('type='));

  if (!userProvidedType) {
    task.type = normalizeTaskType(meta.type, schemaTypes);
  }

  if (!task.id || typeof task.id !== 'string' || !task.id.trim()) {
    task.id = deriveTaskIdentityFromNumber(task, nextTaskNumber(targetDir), meta.slug).id;
  }

  const errors = validate(task, schema);
  if (errors.length > 0) {
    console.error('Task validation failed:');
    for (const err of errors) console.error(`- ${err}`);
    process.exit(1);
  }

  const force = args.values.force === 'true';
  const savedPath = await writeTaskFile(targetDir, task, force, schema);
  console.log(`Task added to ${savedPath}`);
}

main().catch((err) => {
  console.error(err.message);
  process.exit(1);
});

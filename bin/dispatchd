#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const os = require('os');
const { spawn, spawnSync } = require('child_process');
const { resolveBoardDir } = require('../lib/workdir');
const { parseDispatchdArgs } = require('../lib/dispatchd');

const DEFAULT_LOG_FILE = path.join(os.tmpdir(), 'code-conveyor-dispatchd.log');

function runLoop(dispatchBin, boardDir, logFile) {
  const out = spawnSync(process.execPath, [dispatchBin, '--board', boardDir], { encoding: 'utf8' });
  const output = `${out.stdout || ''}${out.stderr || ''}`;
  if (output.trim()) fs.appendFileSync(logFile, output);
  setTimeout(() => runLoop(dispatchBin, boardDir, logFile), 5000);
}

function main() {
  let args;
  try {
    args = parseDispatchdArgs(process.argv.slice(2));
  } catch (e) {
    process.stderr.write(`Error: ${e.message}\n`);
    process.exit(1);
  }
  if (args.help) {
    process.stdout.write('Usage:\n  dispatchd [--log-file <path>] [--board <path>]\n');
    process.exit(0);
  }

  if (args.daemon) {
    const dispatchBin = path.join(__dirname, 'dispatch');
    const logFile = args.logFile || DEFAULT_LOG_FILE;
    runLoop(dispatchBin, args.board, logFile);
    return;
  }

  const logFile = args.logFile || DEFAULT_LOG_FILE;
  const boardDir = resolveBoardDir({ startDir: process.env.PWD || process.cwd(), pathHint: args.board || undefined });

  const logFd = fs.openSync(logFile, 'a');
  const child = spawn(process.execPath, [
    __filename,
    '--daemon',
    '--board', boardDir,
    '--log-file', logFile,
  ], {
    detached: true,
    stdio: ['ignore', logFd, logFd],
  });
  fs.closeSync(logFd);
  child.unref();
  process.stdout.write(`PID: ${child.pid}\n`);
}

main();

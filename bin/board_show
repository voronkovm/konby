#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { spawnSync, spawn } = require('child_process');
const { listTaskSessions, sessionIdPrefix } = require('../lib/tmux_sessions');
const { resolveBoardDir } = require('../lib/workdir');
const { loadYaml, formatYaml, saveYaml } = require('../lib/yaml');
const { readAgentNames, readSchemaEnum } = require('../lib/board_show_io');
const {
  appendMoveComment,
  buildMoveOptionsFromData,
  buildTasksByColumn,
  clampScrollOffset,
  moveSelection,
  nextMoveField,
  normalizeSelection,
  parseBoardShowArgs,
  parseMouseWheelDelta,
  renderBoard,
  renderTaskDetails,
  selectedTask,
  uniqInOrder,
} = require('../lib/board_show');

function locateDispatch(projectDir) {
  const candidates = ['dispatch.yaml'];
  for (const name of candidates) {
    const full = path.join(projectDir, name);
    if (fs.existsSync(full)) return full;
  }
  throw new Error('dispatch.yaml does not exist');
}

function readTasks(tasksDir) {
  if (!fs.existsSync(tasksDir)) return [];
  const files = fs.readdirSync(tasksDir).filter((f) => /\.ya?ml$/i.test(f));
  return files
    .map((file) => {
      const full = path.join(tasksDir, file);
      const data = loadYaml(full);
      return {
        file,
        path: full,
        data,
        id: data.id || file.replace(/\.ya?ml$/i, ''),
        title: data.title || '',
        column: data.column || data.stage || 'backlog',
        status: data.status || 'todo',
        assignee: data.assignee || '-',
      };
    })
    .sort((a, b) => a.file.localeCompare(b.file));
}

function loadBoard(projectDir) {
  const dispatchFile = locateDispatch(projectDir);
  const cfg = loadYaml(dispatchFile);
  const columns = cfg.board && Array.isArray(cfg.board.columns) ? cfg.board.columns : [];
  if (columns.length === 0) throw new Error(`No board.columns in ${path.basename(dispatchFile)}`);
  const tasksDir = path.join(projectDir, 'tasks');
  const tasks = readTasks(tasksDir);
  const tasksByColumn = buildTasksByColumn(columns, tasks);
  return { dispatchFile, tasksDir, columns, tasksByColumn, tasks };
}

function snapshotInputs(projectDir) {
  const parts = [];
  const dispatchCandidates = ['dispatch.yaml'].map((f) => path.join(projectDir, f));
  for (const file of dispatchCandidates) {
    try {
      const st = fs.statSync(file);
      parts.push(`${file}:${st.mtimeMs}:${st.size}`);
    } catch (_) {
      parts.push(`${file}:missing`);
    }
  }

  const tasksDir = path.join(projectDir, 'tasks');
  try {
    const files = fs.readdirSync(tasksDir).filter((f) => /\.ya?ml$/i.test(f)).sort();
    for (const file of files) {
      const full = path.join(tasksDir, file);
      try {
        const st = fs.statSync(full);
        parts.push(`${full}:${st.mtimeMs}:${st.size}`);
      } catch (_) {
        parts.push(`${full}:missing`);
      }
    }
  } catch (_) {
    parts.push(`${tasksDir}:missing`);
  }

  return parts.join('|');
}

function refreshBoard(stateRef) {
  stateRef.board = loadBoard(stateRef.projectDir);
  normalizeSelection(stateRef);
}

function redraw(stateRef) {
  try {
    const output = stateRef.mode === 'details' || stateRef.mode === 'comment'
      ? renderTaskDetails(stateRef, { width: process.stdout.columns || 120, height: process.stdout.rows || 40 })
      : renderBoard(stateRef, { width: process.stdout.columns || 120 });
    process.stdout.write('\x1b[H\x1b[J');
    process.stdout.write(`${output}\n`);
  } catch (err) {
    process.stdout.write('\x1b[H\x1b[J');
    process.stdout.write(`KANBAN ERROR\n\n${err.message}\n`);
  }
}

function setMessage(stateRef, text) {
  stateRef.message = text;
  stateRef.messageAt = Date.now();
}

function runScriptOrThrow(scriptName, args) {
  const scriptPath = path.join(__dirname, scriptName);
  const out = spawnSync(scriptPath, args, {
    encoding: 'utf8',
    cwd: process.cwd(),
  });
  if (out.status !== 0) {
    const detail = String(out.stderr || out.stdout || '').trim();
    throw new Error(detail || `${scriptName} failed`);
  }
}

function updateTaskFile(task, updates) {
  const args = [task.path];
  if (updates.column !== undefined) args.push('--column', String(updates.column));
  if (updates.status !== undefined) args.push('--status', String(updates.status));
  if (updates.assignee !== undefined) args.push('--assignee', String(updates.assignee));
  if (updates.comment !== undefined) args.push('--comment', String(updates.comment));
  runScriptOrThrow('task_move', args);
}

function startConfirmArchive(stateRef) {
  const task = selectedTask(stateRef);
  if (!task) {
    setMessage(stateRef, 'No task selected');
    return;
  }
  stateRef.mode = 'confirm_archive';
}

function handleConfirmArchiveInput(stateRef, key) {
  if (key === '' || key === 'n' || key === 'N') {
    stateRef.mode = 'normal';
    setMessage(stateRef, 'Archive canceled');
    return;
  }
  if (key === '\r' || key === 'y' || key === 'Y') {
    const task = selectedTask(stateRef);
    stateRef.mode = 'normal';
    if (!task) return;
    try {
      runScriptOrThrow('task_archive', [task.path]);
      setMessage(stateRef, `Task archived: ${task.file}`);
      refreshBoard(stateRef);
    } catch (err) {
      setMessage(stateRef, `Archive failed: ${err.message}`);
    }
  }
}

function addTaskComment(task, text) {
  const data = loadYaml(task.path);
  if (!Array.isArray(data.updates)) data.updates = [];
  data.updates.push({
    author: 'user',
    text,
    created_at: new Date().toISOString(),
  });
  data.updated_at = new Date().toISOString();
  saveYaml(task.path, data);
}

function addTask(projectDir, title) {
  runScriptOrThrow('task_add', ['--board', projectDir, '--title', title]);
}

function startMovePopup(stateRef) {
  const task = selectedTask(stateRef);
  if (!task) {
    setMessage(stateRef, 'No task selected');
    return;
  }
  stateRef.mode = 'move';
  stateRef.moveField = 'column';
  stateRef.moveDraft = {
    column: task.column,
    status: task.status,
    assignee: task.assignee,
    comment: '',
  };
  stateRef.moveOptions = buildMoveOptions(stateRef);
  stateRef.moveIndex = {
    column: Math.max(0, stateRef.moveOptions.column.indexOf(stateRef.moveDraft.column)),
    status: Math.max(0, stateRef.moveOptions.status.indexOf(stateRef.moveDraft.status)),
    assignee: Math.max(0, stateRef.moveOptions.assignee.indexOf(stateRef.moveDraft.assignee)),
  };
  for (const field of ['column', 'status', 'assignee']) {
    if (!stateRef.moveOptions[field][stateRef.moveIndex[field]] && stateRef.moveOptions[field].length > 0) {
      stateRef.moveIndex[field] = 0;
    }
    if (stateRef.moveOptions[field].length > 0) {
      stateRef.moveDraft[field] = stateRef.moveOptions[field][stateRef.moveIndex[field]];
    }
  }
}

function buildMoveOptions(stateRef) {
  const columns = stateRef.board && Array.isArray(stateRef.board.columns) ? stateRef.board.columns : [];
  const schemaStatuses = readSchemaEnum(stateRef.projectDir, 'status');
  const agentsFromDir = readAgentNames(stateRef.projectDir);
  return buildMoveOptionsFromData(columns, schemaStatuses, agentsFromDir);
}

function handleMoveInput(stateRef, key) {
  if (key === '\u001b') {
    stateRef.mode = 'normal';
    setMessage(stateRef, 'Move canceled');
    return;
  }
  if (key === '\u001b[A') {
    stateRef.moveField = nextMoveField(stateRef.moveField, -1);
    return;
  }
  if (key === '\u001b[B') {
    stateRef.moveField = nextMoveField(stateRef.moveField, 1);
    return;
  }
  if (stateRef.moveField === 'comment') {
    if (key === '\u007f') {
      stateRef.moveDraft.comment = stateRef.moveDraft.comment.slice(0, -1);
      return;
    }
    if (key === '\t') return;
    if (key !== '\r') {
      appendMoveComment(stateRef, key);
      return;
    }
  }
  if (key === '\u001b[D') {
    const f = stateRef.moveField;
    const opts = stateRef.moveOptions[f] || [];
    if (opts.length === 0) return;
    const delta = -1;
    const next = (stateRef.moveIndex[f] + delta + opts.length) % opts.length;
    stateRef.moveIndex[f] = next;
    stateRef.moveDraft[f] = opts[next];
    return;
  }
  if (key === '\u001b[C') {
    const f = stateRef.moveField;
    const opts = stateRef.moveOptions[f] || [];
    if (opts.length === 0) return;
    const delta = 1;
    const next = (stateRef.moveIndex[f] + delta + opts.length) % opts.length;
    stateRef.moveIndex[f] = next;
    stateRef.moveDraft[f] = opts[next];
    return;
  }
  if (key === '\r') {
    const task = selectedTask(stateRef);
    if (!task) {
      stateRef.mode = 'normal';
      return;
    }
    try {
      const updates = {
        column: stateRef.moveDraft.column,
        status: stateRef.moveDraft.status,
        assignee: stateRef.moveDraft.assignee,
      };
      const commentText = String(stateRef.moveDraft.comment || '').trim();
      if (commentText) updates.comment = commentText;
      updateTaskFile(task, updates);
      stateRef.mode = 'normal';
      setMessage(stateRef, `Task ${task.file} updated`);
      refreshBoard(stateRef);
    } catch (err) {
      stateRef.mode = 'normal';
      setMessage(stateRef, `Move failed: ${err.message}`);
    }
    return;
  }
}

function handleAddInput(stateRef, key) {
  if (key === '\u001b') {
    stateRef.mode = 'normal';
    setMessage(stateRef, 'Add canceled');
    return;
  }
  if (key === '\r') {
    const title = stateRef.addBuffer.trim();
    if (!title) {
      stateRef.mode = 'normal';
      setMessage(stateRef, 'Empty title, canceled');
      return;
    }
    try {
      addTask(stateRef.projectDir, title);
      stateRef.mode = 'normal';
      stateRef.addBuffer = '';
      setMessage(stateRef, 'Task added');
      refreshBoard(stateRef);
    } catch (err) {
      stateRef.mode = 'normal';
      stateRef.addBuffer = '';
      setMessage(stateRef, `Add failed: ${err.message}`);
    }
    return;
  }
  if (key === '\u007f') {
    stateRef.addBuffer = stateRef.addBuffer.slice(0, -1);
    return;
  }
  if (key >= ' ' && key <= '~') stateRef.addBuffer += key;
}

function startDetails(stateRef) {
  const task = selectedTask(stateRef);
  if (!task) {
    setMessage(stateRef, 'No task selected');
    return;
  }
  stateRef.mode = 'details';
  stateRef.detailsScroll = 0;
}

function handleCommentInput(stateRef, key) {
  if (key === '\u001b') {
    stateRef.mode = 'details';
    setMessage(stateRef, 'Comment canceled');
    return;
  }
  if (key === '\r') {
    const task = selectedTask(stateRef);
    const text = stateRef.commentBuffer.trim();
    stateRef.commentBuffer = '';
    if (!task || !text) {
      stateRef.mode = 'details';
      setMessage(stateRef, 'Empty comment, canceled');
      return;
    }
    addTaskComment(task, text);
    refreshBoard(stateRef);
    stateRef.mode = 'details';
    setMessage(stateRef, 'Comment added');
    return;
  }
  if (key === '\u007f') {
    stateRef.commentBuffer = stateRef.commentBuffer.slice(0, -1);
    return;
  }
  if (key >= ' ' && key <= '~') stateRef.commentBuffer += key;
}

function scrollDetails(stateRef, delta) {
  const task = selectedTask(stateRef);
  if (!task) return;
  const detailsLines = formatYaml(task.data).split('\n').length;
  const bodyHeight = Math.max(5, (process.stdout.rows || 40) - 6);
  stateRef.detailsScroll = clampScrollOffset(stateRef.detailsScroll, delta, detailsLines, bodyHeight);
}

function tmuxSessionExists(sessionId) {
  const out = spawnSync('tmux', ['has-session', '-t', sessionId], { encoding: 'utf8' });
  return out.status === 0;
}

function openTaskTmux(stateRef) {
  const task = selectedTask(stateRef);
  if (!task) {
    setMessage(stateRef, 'No task selected');
    return;
  }
  const agent = String(task.assignee || '').trim();
  if (!agent || agent === '-') {
    setMessage(stateRef, 'Task has no assignee agent');
    return;
  }
  const sessionId = sessionIdPrefix(agent, task.file);
  const sessions = listTaskSessions(task.file, { agent, includeLegacyPrefix: true });
  // Prefer the freshest tmux session matching the task prefix.
  // Fallback to exact (legacy) session id without timestamp suffix.
  const targetSessionId = sessions.length > 0
    ? sessions[0].name
    : (tmuxSessionExists(sessionId) ? sessionId : '');
  if (!targetSessionId) {
    setMessage(stateRef, `tmux session not found for task: ${sessionId}`);
    return;
  }

  process.stdin.setRawMode(false);
  process.stdout.write('\x1Bc');
  process.stdout.write(`Opening tmux session: ${targetSessionId}\n`);
  spawnSync('tmux', ['bind-key', '-n', 'C-]', 'detach-client'], { encoding: 'utf8' });
  spawnSync('tmux', ['set-option', '-t', targetSessionId, 'status-right', 'Back to kanban board: Ctrl+]'], { encoding: 'utf8' });
  const out = spawnSync('tmux', ['attach-session', '-t', targetSessionId], { stdio: 'inherit' });
  process.stdin.setRawMode(true);
  process.stdin.resume();

  if (out.status !== 0) {
    const err = (out.error && out.error.message) ? out.error.message : `exit=${out.status}`;
    setMessage(stateRef, `Failed to open tmux: ${err}`);
    return;
  }
  setMessage(stateRef, `Returned from tmux: ${targetSessionId}`);
}

function runDispatchOnce(stateRef) {
  if (stateRef.dispatching) {
    setMessage(stateRef, 'Dispatch already running...');
    return;
  }
  stateRef.dispatching = true;
  setMessage(stateRef, 'Dispatching...');
  redraw(stateRef);

  const dispatchBin = path.join(__dirname, 'dispatch');
  const child = spawn(dispatchBin, ['--board', stateRef.projectDir]);
  let stdout = '';
  let stderr = '';
  child.stdout.on('data', (chunk) => { stdout += chunk; });
  child.stderr.on('data', (chunk) => { stderr += chunk; });
  child.on('close', (code) => {
    stateRef.dispatching = false;
    const output = stdout.trim() || stderr.trim();
    if (code !== 0) {
      setMessage(stateRef, output ? `Dispatch failed: ${output}` : `Dispatch failed (exit=${code})`);
    } else {
      setMessage(stateRef, output || 'Dispatch finished');
    }
    refreshBoard(stateRef);
    redraw(stateRef);
  });
}

function runTaskAction(stateRef, scriptName, successMsg) {
  const task = selectedTask(stateRef);
  if (!task) {
    setMessage(stateRef, 'No task selected');
    return;
  }
  try {
    runScriptOrThrow(scriptName, [task.path]);
    setMessage(stateRef, successMsg);
    refreshBoard(stateRef);
  } catch (err) {
    setMessage(stateRef, `${scriptName} failed: ${err.message}`);
  }
}

function startConfirmMerge(stateRef) {
  const task = selectedTask(stateRef);
  if (!task) {
    setMessage(stateRef, 'No task selected');
    return;
  }
  stateRef.mode = 'confirm_merge';
}

function handleConfirmMergeInput(stateRef, key) {
  if (key === '\u001b' || key === 'n' || key === 'N') {
    stateRef.mode = 'normal';
    setMessage(stateRef, 'Merge canceled');
    return;
  }
  if (key === '\r' || key === 'y' || key === 'Y') {
    stateRef.mode = 'normal';
    runTaskAction(stateRef, 'task_merge', 'Merge executed');
  }
}

function main() {
  const { help, boardPathHint } = parseBoardShowArgs(process.argv.slice(2));
  if (help) {
    process.stdout.write('Usage: board_show [path] [--board <path>]\n');
    return;
  }
  const projectDir = resolveBoardDir({ startDir: process.env.PWD || process.cwd(), pathHint: boardPathHint });

  const stateRef = {
    projectDir,
    board: loadBoard(projectDir),
    selectedCol: 0,
    selectedTask: 0,
    mode: 'normal',
    moveField: 'column',
    moveDraft: { column: '', status: '', assignee: '', comment: '' },
    moveOptions: { column: [], status: [], assignee: [] },
    moveIndex: { column: 0, status: 0, assignee: 0 },
    addBuffer: '',
    commentBuffer: '',
    detailsScroll: 0,
    message: '',
    messageAt: 0,
    dispatching: false,
  };
  normalizeSelection(stateRef);
  redraw(stateRef);

  let lastSnapshot = snapshotInputs(projectDir);
  const timer = setInterval(() => {
    if (stateRef.message && stateRef.messageAt && Date.now() - stateRef.messageAt >= 5000) {
      stateRef.message = '';
      stateRef.messageAt = 0;
      redraw(stateRef);
    }

    const current = snapshotInputs(projectDir);
    if (current === lastSnapshot) return;
    lastSnapshot = current;
    try {
      refreshBoard(stateRef);
      if ((stateRef.mode === 'details' || stateRef.mode === 'comment') && !selectedTask(stateRef)) {
        stateRef.mode = 'normal';
        setMessage(stateRef, 'Task no longer exists');
      }
      redraw(stateRef);
    } catch (err) {
      setMessage(stateRef, err.message);
      redraw(stateRef);
    }
  }, 300);

  if (!process.stdin.isTTY || typeof process.stdin.setRawMode !== 'function') {
    clearInterval(timer);
    process.stdout.write('Interactive TUI requires a TTY terminal.\n');
    process.exit(1);
  }

  process.stdin.setRawMode(true);
  process.stdin.resume();
  process.stdin.setEncoding('utf8');

  const shutdown = () => {
    clearInterval(timer);
    process.stdin.setRawMode(false);
    process.stdin.pause();
    process.stdout.write('\n');
    process.exit(0);
  };

  process.stdin.on('data', (key) => {
    if (key === '\u0003') {
      shutdown();
      return;
    }

    const wheelDelta = parseMouseWheelDelta(key);
    if ((stateRef.mode === 'details' || stateRef.mode === 'comment') && wheelDelta !== 0) {
      scrollDetails(stateRef, wheelDelta);
      redraw(stateRef);
      return;
    }

    if (stateRef.mode === 'move') {
      handleMoveInput(stateRef, key);
      redraw(stateRef);
      return;
    }

    if (stateRef.mode === 'comment') {
      handleCommentInput(stateRef, key);
      redraw(stateRef);
      return;
    }

    if (stateRef.mode === 'add') {
      handleAddInput(stateRef, key);
      redraw(stateRef);
      return;
    }

    if (stateRef.mode === 'confirm_merge') {
      handleConfirmMergeInput(stateRef, key);
      redraw(stateRef);
      return;
    }

    if (stateRef.mode === 'confirm_archive') {
      handleConfirmArchiveInput(stateRef, key);
      redraw(stateRef);
      return;
    }

    if (stateRef.mode === 'details') {
      if (key === '\u001b') {
        stateRef.mode = 'normal';
      } else if (key === '\u001b[A') {
        scrollDetails(stateRef, -1);
      } else if (key === '\u001b[B') {
        scrollDetails(stateRef, 1);
      } else if (key === 'c') {
        stateRef.mode = 'comment';
        stateRef.commentBuffer = '';
      } else if (key === 'a') {
        stateRef.mode = 'add';
        stateRef.addBuffer = '';
      } else if (key === 'm') {
        startMovePopup(stateRef);
      } else if (key === 'x') {
        startConfirmArchive(stateRef);
      } else if (key === 't') {
        openTaskTmux(stateRef);
      } else if (key === 'p') {
        runTaskAction(stateRef, 'task_pr', 'PR flow executed');
      } else if (key === 'g') {
        startConfirmMerge(stateRef);
      } else if (key === 'd') {
        runDispatchOnce(stateRef);
      }
      redraw(stateRef);
      return;
    }

    if (key === '\u001b[A') moveSelection(stateRef, 0, -1);
    else if (key === '\u001b[B') moveSelection(stateRef, 0, 1);
    else if (key === '\u001b[C') moveSelection(stateRef, 1, 0);
    else if (key === '\u001b[D') moveSelection(stateRef, -1, 0);
    else if (key === 'a') {
      stateRef.mode = 'add';
      stateRef.addBuffer = '';
    } else if (key === 'm') {
      startMovePopup(stateRef);
    } else if (key === 'x') {
      startConfirmArchive(stateRef);
    } else if (key === 't') {
      openTaskTmux(stateRef);
    } else if (key === 'p') {
      runTaskAction(stateRef, 'task_pr', 'PR flow executed');
    } else if (key === 'g') {
      startConfirmMerge(stateRef);
    } else if (key === 'd') {
      runDispatchOnce(stateRef);
    } else if (key === '\r') {
      startDetails(stateRef);
    }

    redraw(stateRef);
  });

  process.on('SIGINT', shutdown);
  process.on('SIGTERM', shutdown);
}

main();

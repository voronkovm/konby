{
  "name": "konby",
  "version": "0.1.0",
  "description": "Konby CLI for board bootstrap and local setup",
  "scripts": {
    "test": "c8 node --test \"test/unit/**/*.test.js\" \"test/integration/**/*.test.js\" \"test/e2e/**/*.test.js\""
  },
  "c8": {
    "all": true,
    "include": ["lib/**/*.js", "bin/*"],
    "extension": [".js", ""],
    "reporter": ["text"],
    "temp-directory": "/tmp/konby-coverage"
  },
  "bin": {
    "konby": "bin/konby"
  },
  "files": [
    "bin",
    "lib",
    "presets",
    "README.md"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "c8": "^11.0.0"
  }
}

{
  "name": "@voronkovm/konby",
  "version": "0.1.1",
  "description": "Konby CLI for board bootstrap and local setup",
  "scripts": {
    "test": "c8 node --test \"test/unit/**/*.test.js\" \"test/integration/**/*.test.js\" \"test/e2e/**/*.test.js\"",
    "prepublishOnly": "npm test",
    "release": "npm version patch && git push --follow-tags && npm publish"
  },
  "c8": {
    "all": true,
    "include": [
      "lib/**/*.js",
      "bin/*"
    ],
    "extension": [
      ".js",
      ""
    ],
    "reporter": [
      "text"
    ],
    "temp-directory": "/tmp/konby-coverage"
  },
  "bin": {
    "konby": "bin/konby"
  },
  "files": [
    "bin",
    "lib",
    "presets",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "devDependencies": {
    "c8": "^11.0.0"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
